<ui:FluentWindow
    x:Class="DexSuite.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:DexSuite.App.ViewModels"
    xmlns:loc="clr-namespace:DexSuite.App.Markup"
    xmlns:conv="clr-namespace:DexSuite.App.Converters"
    xmlns:svc="clr-namespace:DexSuite.App.Services"
    xmlns:mdl="clr-namespace:DexSuite.App.Models"
    mc:Ignorable="d"
    Title="DexSuite"
    Icon="pack://application:,,,/Assets/AppIcon.png"
    Width="1280"
    Height="820"
    MinWidth="1080"
    MinHeight="640"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:KeyToTranslationConverter x:Key="Loc"/>

        <!-- ===== Sidebar: nav items con profundidad, acento cian y glow ===== -->
        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="12,11"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Barra de acento lateral izquierda (visible solo en activo) -->
                            <Border x:Name="AccentBar"
                                    Grid.Column="0"
                                    Width="3"
                                    Margin="0,5"
                                    CornerRadius="2"
                                    Background="Transparent"/>

                            <!-- Fondo + borde + contenido -->
                            <Border x:Name="Bd"
                                    Grid.Column="1"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Hover: fondo cian muy sutil + borde cian tenue -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1000B8D9"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2800B8D9"/>
                            </Trigger>
                            <!-- Activo: barra cian + glow de fondo + texto/icono cian -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="AccentBar" Property="Background" Value="#FF00E5FF"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1400E5FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3500E5FF"/>
                                <Setter Property="Foreground" Value="#FF00D9FF"/>
                            </Trigger>
                            <!-- Activo + hover: ligeramente más brillante -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#2000E5FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4800E5FF"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icono del nav item -->
        <Style x:Key="NavItemIconStyle" TargetType="ui:SymbolIcon">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="NavItemTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="SidebarCaption" TargetType="ui:TextBlock">
            <Setter Property="Margin" Value="22,14,16,4"/>
            <Setter Property="Opacity" Value="0.4"/>
            <Setter Property="FontTypography" Value="Caption"/>
        </Style>

        <!-- Card de módulo: acción + badge de impacto + "?" con tooltip completo -->
        <DataTemplate x:Key="ModuleCardTemplate">
            <Border Margin="0,0,0,5"
                    Padding="10,9"
                    CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <!-- Dimming cuando el módulo está bloqueado por tier -->
                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                <Setter Property="Opacity" Value="0.48"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Checkbox: deshabilitado cuando está bloqueado -->
                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- Nombre del módulo -->
                    <ui:TextBlock Grid.Column="1"
                                  Text="{Binding Name}"
                                  FontTypography="BodyStrong"
                                  VerticalAlignment="Center"
                                  TextWrapping="Wrap"/>

                    <!-- Badge de impacto en rendimiento (colored chip) -->
                    <Border Grid.Column="2"
                            Padding="5,2"
                            CornerRadius="4"
                            VerticalAlignment="Center"
                            Margin="6,0,5,0"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1A6B7280"/>
                                <Setter Property="BorderBrush" Value="#2A6B7280"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Impact}" Value="Soft">
                                        <Setter Property="Background" Value="#1A4CAF50"/>
                                        <Setter Property="BorderBrush" Value="#3A4CAF50"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Impact}" Value="Notable">
                                        <Setter Property="Background" Value="#20FFB800"/>
                                        <Setter Property="BorderBrush" Value="#40FFB800"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Impact}" Value="Strong">
                                        <Setter Property="Background" Value="#20FF8C00"/>
                                        <Setter Property="BorderBrush" Value="#40FF8C00"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Impact}" Value="Extreme">
                                        <Setter Property="Background" Value="#20FF5470"/>
                                        <Setter Property="BorderBrush" Value="#42FF5470"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ui:TextBlock Text="{Binding ImpactLabelKey, Converter={StaticResource Loc}}"
                                      FontTypography="Caption"
                                      FontWeight="SemiBold">
                            <ui:TextBlock.Style>
                                <Style TargetType="ui:TextBlock">
                                    <Setter Property="Foreground" Value="#FF6B7280"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Impact}" Value="Soft">
                                            <Setter Property="Foreground" Value="#FF66BB6A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Impact}" Value="Notable">
                                            <Setter Property="Foreground" Value="#FFFFCC00"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Impact}" Value="Strong">
                                            <Setter Property="Foreground" Value="#FFFF9500"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Impact}" Value="Extreme">
                                            <Setter Property="Foreground" Value="#FFFF5470"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:TextBlock.Style>
                        </ui:TextBlock>
                    </Border>

                    <!-- Botón ? — tooltip con nombre, descripción y nota de seguridad -->
                    <Border Grid.Column="3"
                            Width="22" Height="22"
                            CornerRadius="11"
                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            Cursor="Help"
                            ToolTipService.ShowDuration="30000"
                            ToolTipService.InitialShowDelay="200">
                        <Border.ToolTip>
                            <ToolTip MaxWidth="370" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Description}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Margin="0,0,0,10"/>
                                    <Separator Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SafetyReason}"
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Opacity="0.75"/>
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <ui:TextBlock Text="?"
                                      FontTypography="Caption"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Border>

                    <!-- Candado: visible solo cuando el módulo está bloqueado por tier -->
                    <Border Grid.Column="4"
                            Width="22" Height="22"
                            CornerRadius="11"
                            VerticalAlignment="Center"
                            Margin="4,0,0,0"
                            Background="#1A9D4EDD"
                            BorderBrush="#3A9D4EDD"
                            BorderThickness="1"
                            ToolTipService.ShowDuration="8000"
                            ToolTipService.InitialShowDelay="300">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.ToolTip>
                            <ToolTip MaxWidth="260" Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding TierLabel}"
                                               FontWeight="SemiBold"
                                               FontSize="12"/>
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <ui:SymbolIcon Symbol="Lock24"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#FFB026FF"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Card de categoría del test de rendimiento -->
        <DataTemplate x:Key="CategoryRowTemplate">
            <Border Margin="0,0,0,6"
                    Padding="12,8"
                    CornerRadius="6"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0"
                                  Text="{Binding Name}"
                                  FontTypography="BodyStrong"
                                  VerticalAlignment="Center"/>
                    <ui:TextBlock Grid.Column="1"
                                  Text="{Binding Detail}"
                                  Opacity="0.7"
                                  VerticalAlignment="Center"/>
                    <ui:TextBlock Grid.Column="2"
                                  Text="{Binding Score, StringFormat={}{0}/100}"
                                  FontTypography="BodyStrong"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="DexSuite — Performance Series"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ================== SIDEBAR ================== -->
            <Border Grid.Column="0"
                    Background="{DynamicResource LayerOnAcrylicFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">

                    <!-- Header: mini-logo + nombre -->
                    <Border DockPanel.Dock="Top"
                            Margin="14,14,14,8"
                            Padding="10,10"
                            CornerRadius="10"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="#4400B8D9"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="38" Height="38" CornerRadius="7" ClipToBounds="True">
                                <Image Source="pack://application:,,,/Assets/AppIcon.png"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <ui:TextBlock Text="DexSuite" FontTypography="BodyStrong"/>
                                <ui:TextBlock Text="{loc:T Key=App.Tagline}"
                                              FontTypography="Caption"
                                              Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Footer: versión + badge PRO -->
                    <Border DockPanel.Dock="Bottom" Margin="14,6,14,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                               FontSize="13"
                                               Foreground="#FF00B8D9"
                                               VerticalAlignment="Center"
                                               Margin="0,0,5,0"/>
                                <ui:TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                                              FontTypography="Caption"
                                              Foreground="#FF00B8D9"
                                              VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Padding="6,2" CornerRadius="4"
                                    Background="#1A9D4EDD"
                                    BorderBrush="#3A9D4EDD"
                                    BorderThickness="1">
                                <ui:TextBlock Text="PRO"
                                              FontTypography="Caption"
                                              Foreground="#FFB026FF"
                                              FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel>
                        <ui:TextBlock Text="{loc:T Key=Navigation.Panel}" Style="{StaticResource SidebarCaption}"/>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsHomeView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Home">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Home24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.Home}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsModulesView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Modules">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="AppsList24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.Modules}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsLogView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Log">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="DocumentText24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.Log}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- Separador con gradiente -->
                        <Border Height="1" Margin="16,14,16,6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Offset="0"   Color="Transparent"/>
                                    <GradientStop Offset="0.3" Color="#FF2A2A4A"/>
                                    <GradientStop Offset="0.7" Color="#FF2A2A4A"/>
                                    <GradientStop Offset="1"   Color="Transparent"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <ui:TextBlock Text="{loc:T Key=Navigation.System}" Style="{StaticResource SidebarCaption}"/>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsSettingsView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Settings">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.Settings}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsUpdatesView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Updates">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowDownload24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.Updates}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsAboutView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="About">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Info24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.About}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ================== CONTENT ================== -->
            <Grid Grid.Column="1">

                <!-- =========== VISTA INICIO =========== -->
                <ScrollViewer Visibility="{Binding IsHomeView, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="980" HorizontalAlignment="Center" Margin="32,28,32,24">
                        <StackPanel>

                            <!-- Hero: logo centrado (el PNG ya incluye el texto "DexSuite") -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                                <Image Source="pack://application:,,,/Assets/AppIcon.png"
                                       Width="220" Height="220"
                                       Stretch="Uniform"/>
                                <ui:TextBlock Text="{loc:T Key=App.Subtitle}"
                                              Opacity="0.7"
                                              HorizontalAlignment="Center"
                                              Margin="0,8,0,0"/>
                            </StackPanel>

                            <ui:TextBlock Text="{loc:T Key=Home.WhatDoYouWantTo}"
                                          FontTypography="Subtitle"
                                          Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,28">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Margin="0,0,8,0"
                                        Padding="18,16" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="Pulse24" FontSize="28"
                                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                                        <ui:TextBlock Text="{loc:T Key=Home.Card.Analyze.Title}"
                                                      FontTypography="BodyStrong"
                                                      Margin="0,10,0,4"/>
                                        <ui:TextBlock Text="{loc:T Key=Home.Card.Analyze.Desc}"
                                                      Opacity="0.7"
                                                      TextWrapping="Wrap"
                                                      Margin="0,0,0,12"/>
                                        <ui:Button Appearance="Primary"
                                                   Content="{loc:T Key=Home.Card.Analyze.Button}"
                                                   Icon="{ui:SymbolIcon Symbol=Play24}"
                                                   Command="{Binding AnalyzeCommand}"
                                                   HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Margin="8,0,8,0"
                                        Padding="18,16" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="Broom24" FontSize="28"
                                                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                                        <ui:TextBlock Text="{loc:T Key=Home.Card.Optimize.Title}"
                                                      FontTypography="BodyStrong"
                                                      Margin="0,10,0,4"/>
                                        <ui:TextBlock Text="{loc:T Key=Home.Card.Optimize.Desc}"
                                                      Opacity="0.7"
                                                      TextWrapping="Wrap"
                                                      Margin="0,0,0,12"/>
                                        <ui:Button Appearance="Secondary"
                                                   Content="{loc:T Key=Home.Card.Optimize.Button}"
                                                   Icon="{ui:SymbolIcon Symbol=AppsList24}"
                                                   Command="{Binding NavigateCommand}"
                                                   CommandParameter="Modules"
                                                   HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Margin="8,0,0,0"
                                        Padding="18,16" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <ui:SymbolIcon Symbol="DocumentBulletList24" FontSize="28"
                                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                                        <ui:TextBlock Text="{loc:T Key=Home.Card.Log.Title}"
                                                      FontTypography="BodyStrong"
                                                      Margin="0,10,0,4"/>
                                        <ui:TextBlock Text="{loc:T Key=Home.Card.Log.Desc}"
                                                      Opacity="0.7"
                                                      TextWrapping="Wrap"
                                                      Margin="0,0,0,12"/>
                                        <ui:Button Appearance="Secondary"
                                                   Content="{loc:T Key=Home.Card.Log.Button}"
                                                   Icon="{ui:SymbolIcon Symbol=DocumentText24}"
                                                   Command="{Binding NavigateCommand}"
                                                   CommandParameter="Log"
                                                   HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <ui:InfoBar Severity="Informational"
                                        Title="{loc:T Key=Home.NotYetAnalyzed.Title}"
                                        Message="{loc:T Key=Home.NotYetAnalyzed.Message}"
                                        IsClosable="False"
                                        IsOpen="True">
                                <ui:InfoBar.Style>
                                    <Style TargetType="ui:InfoBar">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasScoreBefore}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:InfoBar.Style>
                            </ui:InfoBar>

                            <!-- Bloque de puntuación -->
                            <Border Padding="24,22" CornerRadius="12"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Visibility="{Binding HasScoreBefore, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="140" Height="140"
                                            CornerRadius="70"
                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <ui:TextBlock Text="{Binding ScoreBefore.Total}"
                                                          FontTypography="Display"
                                                          Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                          HorizontalAlignment="Center"/>
                                            <ui:TextBlock Text="/ 100"
                                                          Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                          Opacity="0.75"
                                                          HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="24,0,12,0" VerticalAlignment="Center">
                                        <ui:TextBlock Text="{loc:T Key=Home.ScoreInitial.Label}"
                                                      FontTypography="Caption"
                                                      Opacity="0.6"/>
                                        <ui:TextBlock Text="{Binding ScoreBefore.Verdict, Converter={StaticResource Loc}}"
                                                      FontTypography="TitleLarge"/>
                                        <ui:TextBlock Text="{Binding ScoreBefore.Timestamp, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                      Opacity="0.55"
                                                      Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                Visibility="{Binding HasComparison, Converter={StaticResource BoolToVis}}">
                                        <Border Width="140" Height="140"
                                                CornerRadius="70"
                                                Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <ui:TextBlock Text="{Binding ScoreAfter.Total}"
                                                              FontTypography="Display"
                                                              HorizontalAlignment="Center"/>
                                                <ui:TextBlock Text="/ 100"
                                                              Opacity="0.75"
                                                              HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ui:TextBlock Text="{Binding ScoreDeltaLabel}"
                                                      FontTypography="BodyStrong"
                                                      HorizontalAlignment="Center"
                                                      Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel Margin="0,18,0,0"
                                        Visibility="{Binding HasScoreBefore, Converter={StaticResource BoolToVis}}">
                                <ui:TextBlock Text="{loc:T Key=Home.Breakdown.Initial}"
                                              FontTypography="Subtitle"
                                              Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ScoreBefore.Categories}"
                                              ItemTemplate="{StaticResource CategoryRowTemplate}"/>
                            </StackPanel>

                            <StackPanel Margin="0,18,0,0"
                                        Visibility="{Binding HasComparison, Converter={StaticResource BoolToVis}}">
                                <ui:TextBlock Text="{loc:T Key=Home.Breakdown.After}"
                                              FontTypography="Subtitle"
                                              Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ScoreAfter.Categories}"
                                              ItemTemplate="{StaticResource CategoryRowTemplate}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,18,0,8"
                                        Visibility="{Binding HasScoreBefore, Converter={StaticResource BoolToVis}}">
                                <ui:Button Appearance="Secondary"
                                           Content="{loc:T Key=Home.ResetScores}"
                                           Icon="{ui:SymbolIcon Symbol=ArrowReset24}"
                                           Command="{Binding ResetScoresCommand}"
                                           Margin="0,0,8,0"/>
                                <ui:Button Appearance="Primary"
                                           Content="{loc:T Key=Home.AnalyzeAgain}"
                                           Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                                           Command="{Binding AnalyzeCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- =========== VISTA MÓDULOS =========== -->
                <Grid Visibility="{Binding IsModulesView, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="24,20,24,12">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                            <ui:Button Appearance="Secondary"
                                       Content="{loc:T Key=Modules.SelectRecommended}"
                                       Command="{Binding SelectRecommendedCommand}"
                                       Margin="0,0,4,0"/>
                            <!-- ? junto a Recomendado — explica los criterios de selección -->
                            <Border Width="20" Height="20"
                                    CornerRadius="10"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0"
                                    Cursor="Help"
                                    ToolTipService.ShowDuration="30000"
                                    ToolTipService.InitialShowDelay="200">
                                <Border.ToolTip>
                                    <ToolTip MaxWidth="380" Padding="12,10">
                                        <TextBlock Text="{Binding [Modules.Recommended.Why], Source={x:Static svc:LocalizationService.Instance}}"
                                                   TextWrapping="Wrap"
                                                   FontSize="12"/>
                                    </ToolTip>
                                </Border.ToolTip>
                                <ui:TextBlock Text="?"
                                              FontTypography="Caption"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </Border>
                            <ui:Button Appearance="Secondary"
                                       Content="{loc:T Key=Modules.SelectAll}"
                                       Command="{Binding SelectAllCommand}"
                                       Margin="0,0,6,0"/>
                            <ui:Button Appearance="Secondary"
                                       Content="{loc:T Key=Modules.DeselectAll}"
                                       Command="{Binding DeselectAllCommand}"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Text="{loc:T Key=Modules.Title}"
                                          FontTypography="TitleLarge"/>
                            <ui:TextBlock Text="{loc:T Key=Modules.Subtitle}"
                                          Opacity="0.65"
                                          TextWrapping="Wrap"
                                          Margin="0,2,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel MaxWidth="1020" HorizontalAlignment="Center" Margin="16,0,16,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── Columna FREE (siempre desbloqueada) ── -->
                            <StackPanel Grid.Column="0" Margin="6,0">
                                <Border Padding="10,6"
                                        Margin="0,0,0,10"
                                        CornerRadius="6"
                                        Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:TextBlock Text="{loc:T Key=Modules.Tier.Free}" FontTypography="BodyStrong"/>
                                            <ui:TextBlock Text="{Binding FreeModules.Count, StringFormat=' · {0}'}"
                                                          Opacity="0.6"/>
                                        </StackPanel>
                                        <!-- Siempre desbloqueado: icono de check -->
                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="CheckmarkCircle24"
                                                       FontSize="14"
                                                       Foreground="#FF4CAF50"
                                                       VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding FreeModules}"
                                              ItemTemplate="{StaticResource ModuleCardTemplate}"/>
                            </StackPanel>

                            <!-- ── Columna AVANZADO (bloqueada si tier = Free) ── -->
                            <StackPanel Grid.Column="1" Margin="6,0">
                                <Border Padding="10,6"
                                        Margin="0,0,0,10"
                                        CornerRadius="6"
                                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:TextBlock Text="{loc:T Key=Modules.Tier.Advanced}"
                                                          FontTypography="BodyStrong"
                                                          Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                                            <ui:TextBlock Text="{Binding AdvancedModules.Count, StringFormat=' · {0}'}"
                                                          Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                          Opacity="0.75"/>
                                        </StackPanel>
                                        <!-- Candado visible solo cuando tier = Free -->
                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="Lock24"
                                                       FontSize="14"
                                                       Foreground="White"
                                                       Opacity="0.8"
                                                       VerticalAlignment="Center">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserTier}" Value="Free">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                        <!-- Check visible cuando tier >= Avanzado -->
                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="CheckmarkCircle24"
                                                       FontSize="14"
                                                       Foreground="White"
                                                       Opacity="0.8"
                                                       VerticalAlignment="Center">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserTier}" Value="Free">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding AdvancedModules}"
                                              ItemTemplate="{StaticResource ModuleCardTemplate}"/>
                            </StackPanel>

                            <!-- ── Columna PRO (bloqueada si tier ≠ Pro) ── -->
                            <StackPanel Grid.Column="2" Margin="6,0">
                                <Border Padding="10,6"
                                        Margin="0,0,0,10"
                                        CornerRadius="6"
                                        Background="{DynamicResource SystemFillColorCautionBackgroundBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:TextBlock Text="{loc:T Key=Modules.Tier.Pro}" FontTypography="BodyStrong"/>
                                            <ui:TextBlock Text="{Binding ProModules.Count, StringFormat=' · {0}'}"
                                                          Opacity="0.6"/>
                                        </StackPanel>
                                        <!-- Candado visible cuando tier ≠ Pro -->
                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="Lock24"
                                                       FontSize="14"
                                                       Foreground="#FFB026FF"
                                                       VerticalAlignment="Center">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserTier}" Value="Pro">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                        <!-- Check visible solo cuando tier = Pro -->
                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="CheckmarkCircle24"
                                                       FontSize="14"
                                                       Foreground="#FFB026FF"
                                                       VerticalAlignment="Center">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserTier}" Value="Pro">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding ProModules}"
                                              ItemTemplate="{StaticResource ModuleCardTemplate}"/>
                            </StackPanel>
                        </Grid>

                        <!-- ═══════════════════════════════════════════════ -->
                        <!--   EXTRA PRO · Gaming  — sección visualmente    -->
                        <!--   diferenciada del resto del plan Pro           -->
                        <!-- ═══════════════════════════════════════════════ -->
                        <Border Margin="0,18,0,0"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="#3A00C853"
                                Background="#0A0F0A">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header gaming -->
                                <Border Grid.Row="0"
                                        Padding="14,12"
                                        CornerRadius="9,9,0,0"
                                        Background="#1500C853">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icono gaming -->
                                        <ui:SymbolIcon Grid.Column="0"
                                                       Symbol="Gamepad24"
                                                       FontSize="22"
                                                       Foreground="#FF00C853"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,14,0"/>

                                        <!-- Título y descripción -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <ui:TextBlock Text="{loc:T Key=Modules.Extra.Title}"
                                                          FontTypography="BodyStrong"
                                                          Foreground="#FF00C853"/>
                                            <ui:TextBlock Text="{loc:T Key=Modules.Extra.Subtitle}"
                                                          FontTypography="Caption"
                                                          Opacity="0.65"
                                                          TextWrapping="Wrap"
                                                          Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Badge PRO + candado/check -->
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Padding="6,2" CornerRadius="4"
                                                    Background="#1A9D4EDD"
                                                    BorderBrush="#3A9D4EDD"
                                                    BorderThickness="1"
                                                    Margin="0,0,10,0">
                                                <ui:TextBlock Text="PRO"
                                                              FontTypography="Caption"
                                                              Foreground="#FFB026FF"
                                                              FontWeight="Bold"/>
                                            </Border>
                                            <!-- Candado: visible cuando tier ≠ Pro -->
                                            <ui:SymbolIcon Symbol="Lock24"
                                                           FontSize="17"
                                                           Foreground="#FF00C853"
                                                           VerticalAlignment="Center">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UserTier}" Value="Pro">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                            <!-- Check: visible solo cuando tier = Pro -->
                                            <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                                           FontSize="17"
                                                           Foreground="#FF00C853"
                                                           VerticalAlignment="Center">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UserTier}" Value="Pro">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Módulos gaming -->
                                <ItemsControl Grid.Row="1"
                                              ItemsSource="{Binding ProExtraModules}"
                                              ItemTemplate="{StaticResource ModuleCardTemplate}"
                                              Margin="10,8,10,10"/>
                            </Grid>
                        </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="24,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock Grid.Column="0"
                                          Text="{Binding StatusMessage}"
                                          VerticalAlignment="Center"
                                          Opacity="0.8"
                                          TextWrapping="Wrap"
                                          MaxHeight="48"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button Appearance="Secondary"
                                           Content="{loc:T Key=Common.Cancel}"
                                           Icon="{ui:SymbolIcon Symbol=Stop24}"
                                           Command="{Binding CancelCommand}"
                                           Margin="0,0,8,0"/>
                                <ui:Button Appearance="Primary"
                                           Content="{loc:T Key=Common.Run}"
                                           Icon="{ui:SymbolIcon Symbol=Play24}"
                                           Command="{Binding RunCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- =========== VISTA REGISTRO =========== -->
                <Grid Visibility="{Binding IsLogView, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="24,20,24,12">
                        <ui:TextBlock Text="{loc:T Key=Log.Title}"
                                      FontTypography="TitleLarge"/>
                        <ui:TextBlock Text="{loc:T Key=Log.Subtitle}"
                                      Opacity="0.65"
                                      TextWrapping="Wrap"
                                      Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="24,0,24,0"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <TextBox Text="{Binding OutputLog, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Padding="12"/>
                    </Border>

                    <Border Grid.Row="2"
                            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="24,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock Grid.Column="0"
                                          Text="{Binding StatusMessage}"
                                          VerticalAlignment="Center"
                                          Opacity="0.8"
                                          TextWrapping="Wrap"
                                          MaxHeight="48"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button Appearance="Secondary"
                                           Content="{loc:T Key=Common.Cancel}"
                                           Icon="{ui:SymbolIcon Symbol=Stop24}"
                                           Command="{Binding CancelCommand}"
                                           Margin="0,0,8,0"/>
                                <ui:Button Appearance="Primary"
                                           Content="{loc:T Key=Common.Run}"
                                           Icon="{ui:SymbolIcon Symbol=Play24}"
                                           Command="{Binding RunCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- =========== VISTA AJUSTES =========== -->
                <ScrollViewer Visibility="{Binding IsSettingsView, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="860" HorizontalAlignment="Center" Margin="32,24,32,32">
                        <StackPanel>
                            <ui:TextBlock Text="{loc:T Key=Settings.Title}" FontTypography="TitleLarge"/>
                            <ui:TextBlock Text="{loc:T Key=Settings.Subtitle}"
                                          Opacity="0.65"
                                          TextWrapping="Wrap"
                                          Margin="0,2,0,18"/>

                            <!-- Idioma -->
                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <ui:TextBlock Text="{loc:T Key=Settings.Language.Title}"
                                                      FontTypography="Subtitle"
                                                      Margin="0,0,0,4"/>
                                        <ui:TextBlock Text="{loc:T Key=Settings.Language.Description}"
                                                      Opacity="0.7"
                                                      TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1"
                                              Width="200"
                                              VerticalAlignment="Center"
                                              ItemsSource="{Binding AvailableLanguages}"
                                              SelectedValuePath="Code"
                                              DisplayMemberPath="NativeName"
                                              SelectedValue="{Binding CurrentLanguage, Mode=TwoWay}"/>
                                </Grid>
                            </Border>

                            <!-- Tier del usuario -->
                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:T Key=Settings.Tier.Title}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,4"/>
                                    <ui:TextBlock Text="{loc:T Key=Settings.Tier.Description}"
                                                  Opacity="0.7"
                                                  TextWrapping="Wrap"
                                                  Margin="0,0,0,12"/>
                                    <ComboBox Width="200" HorizontalAlignment="Left"
                                              ItemsSource="{Binding AvailableTiers}"
                                              SelectedItem="{Binding UserTier, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- Comportamiento -->
                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:T Key=Settings.Behavior.Title}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,8"/>

                                    <Grid Margin="0,6,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Settings.AutoSelect.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Settings.AutoSelect.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ui:ToggleSwitch Grid.Column="1"
                                                         IsChecked="{Binding AutoSelectRecommended, Mode=TwoWay}"/>
                                    </Grid>

                                    <Grid Margin="0,6,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Settings.JumpToLog.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Settings.JumpToLog.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ui:ToggleSwitch Grid.Column="1"
                                                         IsChecked="{Binding JumpToLogOnRun, Mode=TwoWay}"/>
                                    </Grid>

                                    <Grid Margin="0,6,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Settings.WarnNonReversible.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Settings.WarnNonReversible.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ui:ToggleSwitch Grid.Column="1"
                                                         IsChecked="{Binding WarnBeforeNonReversible, Mode=TwoWay}"/>
                                    </Grid>

                                    <Grid Margin="0,6,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Settings.NotifyOnFinish.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Settings.NotifyOnFinish.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ui:ToggleSwitch Grid.Column="1"
                                                         IsChecked="{Binding NotifyOnFinish, Mode=TwoWay}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,12,0,0">
                                <ui:Button Appearance="Secondary"
                                           Content="{loc:T Key=Settings.Reset}"
                                           Icon="{ui:SymbolIcon Symbol=ArrowReset24}"
                                           Command="{Binding ResetSettingsCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- =========== VISTA ACTUALIZACIONES =========== -->
                <ScrollViewer Visibility="{Binding IsUpdatesView, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="780" HorizontalAlignment="Center" Margin="32,24,32,32">
                        <StackPanel>
                            <ui:TextBlock Text="{loc:T Key=Updates.Title}" FontTypography="TitleLarge"/>
                            <ui:TextBlock Text="{loc:T Key=Updates.Subtitle}"
                                          Opacity="0.65"
                                          TextWrapping="Wrap"
                                          Margin="0,2,0,18"/>

                            <!-- Tarjeta: versión actual + botón buscar -->
                            <Border Padding="20,18" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <ui:TextBlock Text="{loc:T Key=Updates.InstalledVersion}"
                                                      FontTypography="Caption"
                                                      Opacity="0.6"/>
                                        <ui:TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                                                      FontTypography="TitleLarge"
                                                      Margin="0,2,0,4"/>
                                        <ui:TextBlock Text="{Binding LastUpdateCheckLabel}"
                                                      Opacity="0.55"
                                                      FontTypography="Caption"/>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1"
                                               Appearance="Primary"
                                               Content="{loc:T Key=Updates.CheckForUpdates}"
                                               Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                                               Command="{Binding CheckForUpdatesCommand}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Banner: actualización disponible (visible solo cuando hay update) -->
                            <Border Padding="20,16" CornerRadius="10"
                                    Margin="0,0,0,12"
                                    Visibility="{Binding HasAvailableUpdate, Converter={StaticResource BoolToVis}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}"/>
                                        <Setter Property="BorderBrush"
                                                Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                                Margin="0,0,16,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                                           FontSize="16"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center"/>
                                            <ui:TextBlock Text="{loc:T Key=Updates.NewVersionAvailable}"
                                                          FontTypography="BodyStrong"
                                                          VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ui:TextBlock Text="{Binding AvailableUpdateVersionLabel}"
                                                      Opacity="0.85"
                                                      Margin="0,0,0,8"/>
                                        <ProgressBar Value="{Binding UpdateDownloadProgress}"
                                                     Maximum="100"
                                                     Height="4"/>
                                        <ui:TextBlock Text="{Binding UpdateDownloadProgress, StringFormat='{}{0}%'}"
                                                      FontTypography="Caption"
                                                      Opacity="0.65"
                                                      Margin="0,4,0,0"
                                                      Visibility="{Binding HasAvailableUpdate, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1"
                                               Appearance="Primary"
                                               Content="{loc:T Key=Updates.UpdateNow}"
                                               Icon="{ui:SymbolIcon Symbol=ArrowDownload24}"
                                               Command="{Binding ApplyUpdateCommand}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Preferencias -->
                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:T Key=Updates.Preferences}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,10"/>

                                    <Grid Margin="0,4,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Updates.AutoUpdate.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Updates.AutoUpdate.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ui:ToggleSwitch Grid.Column="1"
                                                         IsChecked="{Binding AutoUpdateEnabled, Mode=TwoWay}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Updates.Channel.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Updates.Channel.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  Width="140"
                                                  VerticalAlignment="Center"
                                                  ItemsSource="{Binding AvailableChannels}"
                                                  SelectedItem="{Binding UpdateChannel, Mode=TwoWay}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Nota informativa sobre Velopack -->
                            <ui:InfoBar Severity="Informational"
                                        Title="{loc:T Key=Updates.HowItWorks.Title}"
                                        Message="{loc:T Key=Updates.HowItWorks.Message}"
                                        IsClosable="False"
                                        IsOpen="True"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- =========== VISTA ACERCA DE =========== -->
                <ScrollViewer Visibility="{Binding IsAboutView, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="860" HorizontalAlignment="Center" Margin="32,28,32,32">
                        <StackPanel>

                            <Border Padding="28,28" CornerRadius="14"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,18">
                                <StackPanel HorizontalAlignment="Center">
                                    <Image Source="pack://application:,,,/Assets/AppIcon.png"
                                           Width="180" Height="180"
                                           Stretch="Uniform"/>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,14,0,0">
                                        <Border Padding="8,3" CornerRadius="4"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                Margin="0,0,6,0">
                                            <ui:TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                                                          Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                          FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,3" CornerRadius="4"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="Requiere administrador"
                                                          FontTypography="Caption"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="El proyecto"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,6"/>
                                    <ui:TextBlock TextWrapping="Wrap" Opacity="0.85">
                                        DexSuite es un sistema de optimización extrema para Windows.<LineBreak/>
                                        Analiza tu equipo, aplica ajustes de alto impacto y empuja el rendimiento al límite físicamente posible.<LineBreak/>
                                        Cada versión incorpora nuevos módulos nativos C# orientados a maximizar FPS y reducir latencias.
                                    </ui:TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="Novedades en v0.1.0"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,8"/>
                                    <StackPanel Margin="0,2,0,2">
                                        <ui:TextBlock Text="• Pantalla de inicio con logo y accesos rápidos"/>
                                        <ui:TextBlock Text="• Test de rendimiento con 8 categorías: CPU, RAM, GPU, Disco, Procesos, Inicio, Temperatura, Red"/>
                                        <ui:TextBlock Text="• Comparativa antes/después con delta de puntuación"/>
                                        <ui:TextBlock Text="• Módulos agrupados por tier (Free / Avanzado / Pro) en 3 columnas"/>
                                        <ui:TextBlock Text="• Chip Seguro/Riesgo con explicación de impacto en cada módulo"/>
                                        <ui:TextBlock Text="• Monitoreo en tiempo real y botón Cancelar durante la ejecución"/>
                                        <ui:TextBlock Text="• Actualización automática integrada"/>
                                        <ui:TextBlock Text="• Tema CYBERNETIC con paleta cian + violeta y logo exclusivo"/>
                                        <ui:TextBlock Text="• Sidebar con iconos, separadores y selector de idioma (10 idiomas)"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="Créditos"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="Diseño y concepto" Opacity="0.6"/>
                                        <ui:TextBlock Grid.Column="1" Text="Sr. Dexter"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="Desarrollo" Opacity="0.6"/>
                                        <ui:TextBlock Grid.Column="1" Text="Mateo · DexSuite Performance Series"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="Módulo videojuegos" Opacity="0.6"/>
                                        <ui:TextBlock Grid.Column="1" Text="Sr. Dexter · Configuración avanzada de juegos"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="Stack técnico"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,10"/>
                                    <WrapPanel>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text=".NET 8" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="C# 12" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="WPF" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="Wpf.Ui (Lepoco)" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="CommunityToolkit.Mvvm" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="EF Core SQLite" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="Serilog" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="Velopack" FontTypography="Caption"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="Utilidades"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,10"/>
                                    <WrapPanel>
                                        <ui:Button Appearance="Secondary"
                                                   Content="Abrir carpeta de logs"
                                                   Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                                                   Command="{Binding OpenLogsFolderCommand}"
                                                   Margin="0,0,8,8"/>
                                        <ui:Button Appearance="Secondary"
                                                   Content="Buscar actualizaciones"
                                                   Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                                                   Command="{Binding CheckForUpdatesCommand}"
                                                   Margin="0,0,8,8"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <ui:TextBlock Text="© 2026 DexSuite · Solo para Windows · Requiere permisos de administrador"
                                          Opacity="0.5"
                                          FontTypography="Caption"
                                          HorizontalAlignment="Center"
                                          Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
