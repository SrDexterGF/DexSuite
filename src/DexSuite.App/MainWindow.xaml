<ui:FluentWindow
    x:Class="DexSuite.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:DexSuite.App.ViewModels"
    xmlns:loc="clr-namespace:DexSuite.App.Markup"
    xmlns:conv="clr-namespace:DexSuite.App.Converters"
    xmlns:svc="clr-namespace:DexSuite.App.Services"
    xmlns:mdl="clr-namespace:DexSuite.App.Models"
    mc:Ignorable="d"
    Title="DexSuite"
    Icon="pack://application:,,,/Assets/AppIcon.png"
    Width="1280"
    Height="820"
    MinWidth="1080"
    MinHeight="640"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:KeyToTranslationConverter x:Key="Loc"/>
        <conv:LocFormatMultiConverter x:Key="LocFormat"/>

        <!-- Converters del historial interno -->
        <conv:LogLevelToBrushConverter    x:Key="LogLevelBrush"/>
        <conv:LogLevelToTextConverter     x:Key="LogLevelText"/>
        <conv:LogCategoryToTextConverter  x:Key="LogCategoryText"/>
        <conv:UtcToLocalTimeConverter     x:Key="UtcToLocalTime"/>

        <!-- Converters: tipo de check de seguridad + tipo de cambio revertible -->
        <conv:SecurityKindConverter       x:Key="SecurityKind"/>
        <conv:ChangeTypeConverter         x:Key="ChangeTypeText"/>

        <!-- Sidebar: nav items -->
        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="12,11"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Barra de acento lateral izquierda (visible solo en activo) -->
                            <Border x:Name="AccentBar"
                                    Grid.Column="0"
                                    Width="3"
                                    Margin="0,5"
                                    CornerRadius="2"
                                    Background="Transparent"/>

                            <!-- Fondo + borde + contenido -->
                            <Border x:Name="Bd"
                                    Grid.Column="1"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Hover: fondo cian muy sutil + borde cian tenue -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1000B8D9"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2800B8D9"/>
                            </Trigger>
                            <!-- Activo: barra cian + glow de fondo + texto/icono cian -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="AccentBar" Property="Background" Value="#FF00E5FF"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1400E5FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3500E5FF"/>
                                <Setter Property="Foreground" Value="#FF00D9FF"/>
                            </Trigger>
                            <!-- Activo + hover: ligeramente más brillante -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#2000E5FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4800E5FF"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para botones de acción en la sidebar (sin barra de acento ni estado activo) -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="12,11"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1000B8D9"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2800B8D9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A00B8D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icono del nav item -->
        <Style x:Key="NavItemIconStyle" TargetType="ui:SymbolIcon">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="NavItemTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="SidebarCaption" TargetType="ui:TextBlock">
            <Setter Property="Margin" Value="22,14,16,4"/>
            <Setter Property="Opacity" Value="0.4"/>
            <Setter Property="FontTypography" Value="Caption"/>
        </Style>

        <!-- Estilo compartido para botones de barra superior.
             SIN BasedOn, los setters pisan el template y los botones pierden
             color/bordes (aparecen planos en blanco). -->
        <Style x:Key="ToolbarButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Sidebar brushes -->
        <SolidColorBrush x:Key="SidebarBorderBrush" Color="#1A00B8D9"/>

        <!-- Card de módulo: acción + badge de impacto + "?" con tooltip completo -->
        <DataTemplate x:Key="ModuleCardTemplate">
            <Border Margin="0,0,0,5"
                    Padding="10,9"
                    CornerRadius="8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <!-- Dimming cuando el módulo está bloqueado por tier -->
                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                <Setter Property="Opacity" Value="0.48"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Indicador de estado del módulo (Idle / Running / Success / Error) -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Checkbox: deshabilitado cuando está bloqueado -->
                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- Nombre del módulo -->
                    <ui:TextBlock Grid.Column="1"
                                  Text="{Binding Name}"
                                  FontTypography="BodyStrong"
                                  VerticalAlignment="Center"
                                  TextWrapping="Wrap"/>

                    <!-- Badge de impacto en rendimiento (colored chip).
                         El tooltip describe qué significa el nivel de impacto. -->
                    <Border Grid.Column="2"
                            Padding="5,2"
                            CornerRadius="4"
                            VerticalAlignment="Center"
                            Margin="6,0,5,0"
                            BorderThickness="1"
                            ToolTipService.ShowDuration="8000"
                            ToolTipService.InitialShowDelay="300"
                            ToolTip="{Binding [Modules.Impact.TooltipDesc], Source={x:Static svc:LocalizationService.Instance}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1A6B7280"/>
                                <Setter Property="BorderBrush" Value="#2A6B7280"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Impact}" Value="Soft">
                                        <Setter Property="Background" Value="#1A4CAF50"/>
                                        <Setter Property="BorderBrush" Value="#3A4CAF50"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Impact}" Value="Notable">
                                        <Setter Property="Background" Value="#20FFB800"/>
                                        <Setter Property="BorderBrush" Value="#40FFB800"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Impact}" Value="Strong">
                                        <Setter Property="Background" Value="#20FF8C00"/>
                                        <Setter Property="BorderBrush" Value="#40FF8C00"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Impact}" Value="Extreme">
                                        <Setter Property="Background" Value="#20FF5470"/>
                                        <Setter Property="BorderBrush" Value="#42FF5470"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ui:TextBlock Text="{Binding ImpactLabelKey, Converter={StaticResource Loc}}"
                                      FontTypography="Caption"
                                      FontWeight="SemiBold">
                            <ui:TextBlock.Style>
                                <Style TargetType="ui:TextBlock">
                                    <Setter Property="Foreground" Value="#FF6B7280"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Impact}" Value="Soft">
                                            <Setter Property="Foreground" Value="#FF66BB6A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Impact}" Value="Notable">
                                            <Setter Property="Foreground" Value="#FFFFCC00"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Impact}" Value="Strong">
                                            <Setter Property="Foreground" Value="#FFFF9500"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Impact}" Value="Extreme">
                                            <Setter Property="Foreground" Value="#FFFF5470"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:TextBlock.Style>
                        </ui:TextBlock>
                    </Border>

                    <!-- Indicador de estado de ejecución del módulo (F2.2).
                         Visualmente:
                           Idle    → guion gris  (— ) opacity 0.4
                           Running → spinner cian indeterminado
                           Success → checkmark verde
                           Error   → triángulo ámbar con tooltip del último error -->
                    <Grid Grid.Column="3"
                          Width="20" Height="20"
                          VerticalAlignment="Center"
                          Margin="2,0,6,0"
                          ToolTipService.ShowDuration="8000"
                          ToolTipService.InitialShowDelay="200">
                        <!-- Idle: guion -->
                        <ui:TextBlock Text="—"
                                      FontSize="14"
                                      FontWeight="SemiBold"
                                      Opacity="0.4"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      ToolTip="{Binding [Modules.Run.IdleTooltip], Source={x:Static svc:LocalizationService.Instance}}">
                            <ui:TextBlock.Style>
                                <Style TargetType="ui:TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RunStatus}" Value="Running">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RunStatus}" Value="Success">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RunStatus}" Value="Error">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:TextBlock.Style>
                        </ui:TextBlock>
                        <!-- Running: spinner -->
                        <ui:ProgressRing IsIndeterminate="True"
                                         Width="18" Height="18"
                                         ToolTip="{Binding [Modules.Run.RunningTooltip], Source={x:Static svc:LocalizationService.Instance}}">
                            <ui:ProgressRing.Style>
                                <Style TargetType="ui:ProgressRing">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RunStatus}" Value="Running">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:ProgressRing.Style>
                        </ui:ProgressRing>
                        <!-- Success: checkmark verde -->
                        <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                       FontSize="18"
                                       Foreground="#FF00C853"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       ToolTip="{Binding [Modules.Run.SuccessTooltip], Source={x:Static svc:LocalizationService.Instance}}">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RunStatus}" Value="Success">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                        <!-- Error: triángulo ámbar — el tooltip se compone con
                             el mensaje real del último error si existe. -->
                        <ui:SymbolIcon Symbol="Warning24"
                                       FontSize="18"
                                       Foreground="#FFFF6E40"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RunStatus}" Value="Error">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                            <ui:SymbolIcon.ToolTip>
                                <ToolTip MaxWidth="320" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding [Modules.Run.ErrorTooltip], Source={x:Static svc:LocalizationService.Instance}}"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"/>
                                        <TextBlock Text="{Binding LastError}"
                                                   TextWrapping="Wrap"
                                                   FontSize="11"
                                                   Opacity="0.85"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </ToolTip>
                            </ui:SymbolIcon.ToolTip>
                        </ui:SymbolIcon>
                    </Grid>

                    <!-- Botón ? — tooltip con nombre, descripción y nota de seguridad -->
                    <Border Grid.Column="4"
                            Width="22" Height="22"
                            CornerRadius="11"
                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            Cursor="Help"
                            ToolTipService.ShowDuration="30000"
                            ToolTipService.InitialShowDelay="200">
                        <Border.ToolTip>
                            <ToolTip MaxWidth="370" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Description}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Margin="0,0,0,10"/>
                                    <Separator Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SafetyReason}"
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Opacity="0.75"/>
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="?"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   LineHeight="22"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Border>

                    <!-- Candado: visible solo cuando el módulo está bloqueado por tier -->
                    <Border Grid.Column="5"
                            Width="22" Height="22"
                            CornerRadius="11"
                            VerticalAlignment="Center"
                            Margin="4,0,0,0"
                            Background="#1A9D4EDD"
                            BorderBrush="#3A9D4EDD"
                            BorderThickness="1"
                            ToolTipService.ShowDuration="8000"
                            ToolTipService.InitialShowDelay="300">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.ToolTip>
                            <ToolTip MaxWidth="260" Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding TierLabel}"
                                               FontWeight="SemiBold"
                                               FontSize="12"/>
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <ui:SymbolIcon Symbol="LockClosed24"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#FFB026FF"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Card de categoría del test de rendimiento -->
        <DataTemplate x:Key="CategoryRowTemplate">
            <Border Margin="0,0,0,6"
                    Padding="12,8"
                    CornerRadius="6"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0"
                                  Text="{Binding Name}"
                                  FontTypography="BodyStrong"
                                  VerticalAlignment="Center"/>
                    <ui:TextBlock Grid.Column="1"
                                  Text="{Binding Detail}"
                                  Opacity="0.7"
                                  VerticalAlignment="Center"/>
                    <ui:TextBlock Grid.Column="2"
                                  Text="{Binding Score, StringFormat={}{0}/100}"
                                  FontTypography="BodyStrong"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="DexSuite — Performance Series"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource LayerOnAcrylicFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SidebarBorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">

                    <!-- Header: mini-logo + nombre -->
                    <Border DockPanel.Dock="Top"
                            Margin="14,14,14,8"
                            Padding="10,10"
                            CornerRadius="10"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="#4400B8D9"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="38" Height="38" CornerRadius="7" ClipToBounds="True">
                                <Image Source="pack://application:,,,/Assets/AppIcon.png"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Aliased"
                                       SnapsToDevicePixels="True"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <ui:TextBlock Text="DexSuite" FontTypography="BodyStrong"/>
                                <ui:TextBlock Text="{loc:T Key=App.Tagline}"
                                              FontTypography="Caption"
                                              Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Footer: versión + badge PRO -->
                    <Border DockPanel.Dock="Bottom" Margin="14,6,14,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                               FontSize="13"
                                               Foreground="#FF00B8D9"
                                               VerticalAlignment="Center"
                                               Margin="0,0,5,0"/>
                                <ui:TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                                              FontTypography="Caption"
                                              Foreground="#FF00B8D9"
                                              VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Padding="6,2" CornerRadius="4"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- Default: Free -->
                                        <Setter Property="Background"   Value="#1A606060"/>
                                        <Setter Property="BorderBrush"  Value="#3A808080"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UserTier}" Value="Pro">
                                                <Setter Property="Background"  Value="#1A9D4EDD"/>
                                                <Setter Property="BorderBrush" Value="#3A9D4EDD"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UserTier}" Value="Advanced">
                                                <Setter Property="Background"  Value="#1A9D4EDD"/>
                                                <Setter Property="BorderBrush" Value="#3A9D4EDD"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ui:TextBlock Text="{Binding UserTier}"
                                              FontTypography="Caption"
                                              FontWeight="Bold">
                                    <ui:TextBlock.Style>
                                        <Style TargetType="ui:TextBlock">
                                            <!-- Default: Free -->
                                            <Setter Property="Foreground" Value="#FF909090"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UserTier}" Value="Pro">
                                                    <Setter Property="Foreground" Value="#FFB026FF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding UserTier}" Value="Advanced">
                                                    <Setter Property="Foreground" Value="#FFB026FF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:TextBlock.Style>
                                </ui:TextBlock>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Botón "Reportar un fallo" anclado sobre el footer -->
                    <Button DockPanel.Dock="Bottom"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ReportBugCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Bug24" Style="{StaticResource NavItemIconStyle}"/>
                            <TextBlock Text="{loc:T Key=BugReport.Button}" Style="{StaticResource NavItemTextStyle}"/>
                        </StackPanel>
                    </Button>

                    <StackPanel>
                        <ui:TextBlock Text="{loc:T Key=Navigation.Panel}" Style="{StaticResource SidebarCaption}"/>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsHomeView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Home">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Home24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.Home}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsModulesView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Modules">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="AppsList24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.Modules}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsLogView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Log">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="DocumentText24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.Log}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsSpecsView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Specs">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Desktop24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.Specs}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- Revertir cambios: badge con número de pendientes en la derecha -->
                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsRestoreView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Restore">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowUndo24" Style="{StaticResource NavItemIconStyle}"/>
                                    <TextBlock Text="{loc:T Key=Navigation.Restore}" Style="{StaticResource NavItemTextStyle}"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Padding="6,1" CornerRadius="9"
                                        Background="#1A00B8D9"
                                        BorderBrush="#3A00B8D9"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Margin="0,0,2,0"
                                        Visibility="{Binding HasPendingChanges, Converter={StaticResource BoolToVis}}">
                                    <ui:TextBlock Text="{Binding PendingChangesCount}"
                                                  FontTypography="Caption"
                                                  FontWeight="Bold"
                                                  Foreground="#FF00B8D9"/>
                                </Border>
                            </Grid>
                        </RadioButton>

                        <!-- Separador con gradiente -->
                        <Border Height="1" Margin="16,14,16,6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Offset="0"   Color="Transparent"/>
                                    <GradientStop Offset="0.3" Color="#FF2A2A4A"/>
                                    <GradientStop Offset="0.7" Color="#FF2A2A4A"/>
                                    <GradientStop Offset="1"   Color="Transparent"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <ui:TextBlock Text="{loc:T Key=Navigation.System}" Style="{StaticResource SidebarCaption}"/>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsSettingsView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Settings">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.Settings}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsUpdatesView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Updates">
                            <StackPanel Orientation="Horizontal">
                                <!-- Flecha verde cuando hay actualización disponible -->
                                <ui:SymbolIcon Symbol="ArrowDownload24">
                                    <ui:SymbolIcon.Style>
                                        <Style TargetType="ui:SymbolIcon" BasedOn="{StaticResource NavItemIconStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                                    <Setter Property="Foreground" Value="#FF00C853"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:SymbolIcon.Style>
                                </ui:SymbolIcon>
                                <TextBlock Text="{loc:T Key=Navigation.Updates}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavItemStyle}"
                                     GroupName="MainNav"
                                     IsChecked="{Binding IsAboutView, Mode=OneWay}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="About">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Info24" Style="{StaticResource NavItemIconStyle}"/>
                                <TextBlock Text="{loc:T Key=Navigation.About}" Style="{StaticResource NavItemTextStyle}"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Contenido -->
            <Grid Grid.Column="1">


                <!-- Vista Inicio -->
                <ScrollViewer Visibility="{Binding IsHomeView, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="980" HorizontalAlignment="Center" Margin="32,28,32,24">
                        <StackPanel>

                            <!-- Hero: logo centrado (el PNG ya incluye el texto "DexSuite") -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                                <Image Source="pack://application:,,,/Assets/AppIcon.png"
                                       Width="220" Height="220"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       SnapsToDevicePixels="True"
                                       UseLayoutRounding="True"/>
                                <ui:TextBlock Text="{loc:T Key=App.Subtitle}"
                                              Opacity="0.7"
                                              HorizontalAlignment="Center"
                                              Margin="0,8,0,0"/>
                            </StackPanel>

                            <ui:TextBlock Text="{loc:T Key=Home.WhatDoYouWantTo}"
                                          FontTypography="Subtitle"
                                          Margin="0,0,0,12"/>
                            <Border Margin="0,0,0,28">
                            <UniformGrid Columns="3" Margin="0,0,-8,-8">

                                <Border Margin="0,0,8,8"
                                        Padding="18,16" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <ui:SymbolIcon Grid.Row="0" Symbol="Pulse24" FontSize="28"
                                                       HorizontalAlignment="Left"
                                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                                        <ui:TextBlock Grid.Row="1" Text="{loc:T Key=Home.Card.Analyze.Title}"
                                                      FontTypography="BodyStrong"
                                                      Margin="0,10,0,4"/>
                                        <ui:TextBlock Grid.Row="2" Text="{loc:T Key=Home.Card.Analyze.Desc}"
                                                      Opacity="0.7"
                                                      TextWrapping="Wrap"
                                                      VerticalAlignment="Top"
                                                      Margin="0,0,0,12"/>
                                        <ui:Button Grid.Row="3" Appearance="Secondary"
                                                   Content="{loc:T Key=Home.Card.Analyze.Button}"
                                                   Icon="{ui:SymbolIcon Symbol=Play24}"
                                                   Command="{Binding AnalyzeCommand}"
                                                   HorizontalAlignment="Left"/>
                                    </Grid>
                                </Border>

                                <Border Margin="0,0,8,8"
                                        Padding="18,16" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <ui:SymbolIcon Grid.Row="0" Symbol="Broom24" FontSize="28"
                                                       HorizontalAlignment="Left"
                                                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                                        <ui:TextBlock Grid.Row="1" Text="{loc:T Key=Home.Card.Optimize.Title}"
                                                      FontTypography="BodyStrong"
                                                      Margin="0,10,0,4"/>
                                        <ui:TextBlock Grid.Row="2" Text="{loc:T Key=Home.Card.Optimize.Desc}"
                                                      Opacity="0.7"
                                                      TextWrapping="Wrap"
                                                      VerticalAlignment="Top"
                                                      Margin="0,0,0,12"/>
                                        <ui:Button Grid.Row="3" Appearance="Secondary"
                                                   Content="{loc:T Key=Home.Card.Optimize.Button}"
                                                   Icon="{ui:SymbolIcon Symbol=AppsList24}"
                                                   Command="{Binding NavigateCommand}"
                                                   CommandParameter="Modules"
                                                   HorizontalAlignment="Left"/>
                                    </Grid>
                                </Border>

                                <Border Margin="0,0,8,8"
                                        Padding="18,16" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <ui:SymbolIcon Grid.Row="0" Symbol="DocumentBulletList24" FontSize="28"
                                                       HorizontalAlignment="Left"
                                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                                        <ui:TextBlock Grid.Row="1" Text="{loc:T Key=Home.Card.Log.Title}"
                                                      FontTypography="BodyStrong"
                                                      Margin="0,10,0,4"/>
                                        <ui:TextBlock Grid.Row="2" Text="{loc:T Key=Home.Card.Log.Desc}"
                                                      Opacity="0.7"
                                                      TextWrapping="Wrap"
                                                      VerticalAlignment="Top"
                                                      Margin="0,0,0,12"/>
                                        <ui:Button Grid.Row="3" Appearance="Secondary"
                                                   Content="{loc:T Key=Home.Card.Log.Button}"
                                                   Icon="{ui:SymbolIcon Symbol=DocumentText24}"
                                                   Command="{Binding NavigateCommand}"
                                                   CommandParameter="Log"
                                                   HorizontalAlignment="Left"/>
                                    </Grid>
                                </Border>

                                <!-- Card: Limpieza rápida -->
                                <Border Margin="0,0,8,8"
                                        Padding="18,16" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <ui:SymbolIcon Grid.Row="0" Symbol="Broom24" FontSize="28"
                                                       HorizontalAlignment="Left"
                                                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                                        <ui:TextBlock Grid.Row="1" Text="{loc:T Key=Home.Card.QuickClean.Title}"
                                                      FontTypography="BodyStrong"
                                                      Margin="0,10,0,4"/>
                                        <ui:TextBlock Grid.Row="2" Text="{loc:T Key=Home.Card.QuickClean.Desc}"
                                                      Opacity="0.7"
                                                      TextWrapping="Wrap"
                                                      VerticalAlignment="Top"
                                                      Margin="0,0,0,12"/>
                                        <ui:Button Grid.Row="3" Appearance="Secondary"
                                                   Padding="14,4,10,4"
                                                   Command="{Binding QuickCleanCommand}"
                                                   HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:SymbolIcon Symbol="Broom24" FontSize="14"
                                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{loc:T Key=Home.Card.QuickClean.Button}"
                                                           VerticalAlignment="Center"/>
                                                <Border Width="16" Height="16"
                                                        Margin="8,0,0,0"
                                                        CornerRadius="8"
                                                        Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Center"
                                                        Cursor="Help"
                                                        PreviewMouseLeftButtonDown="OnQuestionMarkPreventClick"
                                                        ToolTipService.ShowDuration="30000"
                                                        ToolTipService.InitialShowDelay="200">
                                                    <Border.ToolTip>
                                                        <ToolTip MaxWidth="360" Padding="12,10">
                                                            <TextBlock Text="{Binding [QuickClean.Tooltip], Source={x:Static svc:LocalizationService.Instance}}"
                                                                       TextWrapping="Wrap"/>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="?" FontSize="10" FontWeight="SemiBold"
                                                               LineHeight="16" TextAlignment="Center"
                                                               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </ui:Button>
                                    </Grid>
                                </Border>

                                <!-- Card: Actualizar aplicaciones (winget) -->
                                <Border Margin="0,0,8,8"
                                        Padding="18,16" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <ui:SymbolIcon Grid.Row="0" Symbol="ArrowDownload24" FontSize="28"
                                                       HorizontalAlignment="Left"
                                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                                        <ui:TextBlock Grid.Row="1" Text="{loc:T Key=Home.Card.WingetUpgrade.Title}"
                                                      FontTypography="BodyStrong"
                                                      Margin="0,10,0,4"/>
                                        <ui:TextBlock Grid.Row="2" Text="{loc:T Key=Home.Card.WingetUpgrade.Desc}"
                                                      Opacity="0.7"
                                                      TextWrapping="Wrap"
                                                      VerticalAlignment="Top"
                                                      Margin="0,0,0,12"/>
                                        <ui:Button Grid.Row="3" Appearance="Secondary"
                                                   Content="{loc:T Key=Home.Card.WingetUpgrade.Button}"
                                                   Icon="{ui:SymbolIcon Symbol=ArrowDownload24}"
                                                   Command="{Binding WingetUpgradeCommand}"
                                                   IsEnabled="{Binding IsWingetAvailable}"
                                                   HorizontalAlignment="Left"/>
                                    </Grid>
                                </Border>

                                <!-- Card: Comprobación de seguridad (Defender / SFC / DISM / MRT) -->
                                <Border Margin="0,0,8,8"
                                        Padding="18,16" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <ui:SymbolIcon Grid.Row="0" Symbol="ShieldCheckmark24" FontSize="28"
                                                       HorizontalAlignment="Left"
                                                       Foreground="{DynamicResource SystemFillColorAttentionBrush}"/>
                                        <ui:TextBlock Grid.Row="1" Text="{loc:T Key=Security.CardTitle}"
                                                      FontTypography="BodyStrong"
                                                      Margin="0,10,0,4"/>
                                        <ui:TextBlock Grid.Row="2" Text="{loc:T Key=Security.CardDesc}"
                                                      Opacity="0.7"
                                                      TextWrapping="Wrap"
                                                      VerticalAlignment="Top"
                                                      Margin="0,0,0,12"/>
                                        <StackPanel Grid.Row="3" Orientation="Vertical">
                                            <ComboBox Margin="0,0,0,8"
                                                      HorizontalAlignment="Stretch"
                                                      ItemsSource="{Binding AvailableSecurityChecks}"
                                                      SelectedItem="{Binding SelectedSecurityCheck, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource SecurityKind}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <ui:Button Appearance="Secondary"
                                                       Content="{loc:T Key=Security.RunButton}"
                                                       Icon="{ui:SymbolIcon Symbol=Play24}"
                                                       Command="{Binding RunSecurityCheckCommand}"
                                                       HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </UniformGrid>
                            </Border>

                            <ui:InfoBar Severity="Informational"
                                        Title="{loc:T Key=Home.NotYetAnalyzed.Title}"
                                        Message="{loc:T Key=Home.NotYetAnalyzed.Message}"
                                        IsClosable="False"
                                        IsOpen="True">
                                <ui:InfoBar.Style>
                                    <Style TargetType="ui:InfoBar">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasScoreBefore}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:InfoBar.Style>
                            </ui:InfoBar>

                            <!-- Bloque de puntuación -->
                            <Border Padding="24,22" CornerRadius="12"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Visibility="{Binding HasScoreBefore, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="140" Height="140"
                                            CornerRadius="70"
                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <ui:TextBlock Text="{Binding ScoreBefore.Total}"
                                                          FontTypography="Display"
                                                          Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                          HorizontalAlignment="Center"/>
                                            <ui:TextBlock Text="/ 100"
                                                          Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                          Opacity="0.75"
                                                          HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="24,0,12,0" VerticalAlignment="Center">
                                        <ui:TextBlock Text="{loc:T Key=Home.ScoreInitial.Label}"
                                                      FontTypography="Caption"
                                                      Opacity="0.6"/>
                                        <ui:TextBlock Text="{Binding ScoreBefore.Verdict, Converter={StaticResource Loc}}"
                                                      FontTypography="TitleLarge"/>
                                        <!-- Timestamp + badge "sesión anterior" si baseline es del disco -->
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <ui:TextBlock Text="{Binding BaselineTimestampLabel}"
                                                          Opacity="0.6"
                                                          FontSize="12"/>
                                            <!-- Badge "sesión anterior" solo si IsBaselineFromFile -->
                                            <Border Margin="8,0,0,0"
                                                    Background="#FF1E3A5F"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBaselineFromFile}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{loc:T Key=Score.BaselineFromFile}"
                                                           FontSize="10"
                                                           Foreground="#FF7AB8F5"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                Visibility="{Binding HasComparison, Converter={StaticResource BoolToVis}}">
                                        <Border Width="140" Height="140"
                                                CornerRadius="70"
                                                Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <ui:TextBlock Text="{Binding ScoreAfter.Total}"
                                                              FontTypography="Display"
                                                              HorizontalAlignment="Center"/>
                                                <ui:TextBlock Text="/ 100"
                                                              Opacity="0.75"
                                                              HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ui:TextBlock Text="{Binding ScoreDeltaLabel}"
                                                      FontTypography="BodyStrong"
                                                      HorizontalAlignment="Center"
                                                      Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel Margin="0,18,0,0"
                                        Visibility="{Binding HasScoreBefore, Converter={StaticResource BoolToVis}}">
                                <ui:TextBlock Text="{loc:T Key=Home.Breakdown.Initial}"
                                              FontTypography="Subtitle"
                                              Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ScoreBefore.Categories}"
                                              ItemTemplate="{StaticResource CategoryRowTemplate}"/>
                            </StackPanel>

                            <StackPanel Margin="0,18,0,0"
                                        Visibility="{Binding HasComparison, Converter={StaticResource BoolToVis}}">
                                <ui:TextBlock Text="{loc:T Key=Home.Breakdown.After}"
                                              FontTypography="Subtitle"
                                              Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ScoreAfter.Categories}"
                                              ItemTemplate="{StaticResource CategoryRowTemplate}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,18,0,8"
                                        Visibility="{Binding HasScoreBefore, Converter={StaticResource BoolToVis}}">
                                <ui:Button Appearance="Secondary"
                                           Content="{loc:T Key=Home.ResetScores}"
                                           Icon="{ui:SymbolIcon Symbol=ArrowReset24}"
                                           Command="{Binding ResetScoresCommand}"
                                           Margin="0,0,8,0"/>
                                <ui:Button Appearance="Primary"
                                           Content="{loc:T Key=Home.AnalyzeAgain}"
                                           Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                                           Command="{Binding AnalyzeCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- Vista Módulos -->
                <Grid Visibility="{Binding IsModulesView, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                    <DockPanel Margin="24,20,24,8">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">

                            <!-- Limpieza rápida — (?) embebido dentro del botón -->
                            <ui:Button Appearance="Secondary"
                                       Style="{StaticResource ToolbarButton}"
                                       Padding="14,4,10,4"
                                       Command="{Binding QuickCleanCommand}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Broom24" FontSize="14"
                                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:T Key=QuickClean.Button}" VerticalAlignment="Center"/>
                                    <Border Width="16" Height="16"
                                            Margin="8,0,0,0"
                                            CornerRadius="8"
                                            Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            VerticalAlignment="Center"
                                            Cursor="Help"
                                            PreviewMouseLeftButtonDown="OnQuestionMarkPreventClick"
                                            ToolTipService.ShowDuration="30000"
                                            ToolTipService.InitialShowDelay="200">
                                        <Border.ToolTip>
                                            <ToolTip MaxWidth="380" Padding="12,10">
                                                <TextBlock Text="{Binding [QuickClean.Tooltip], Source={x:Static svc:LocalizationService.Instance}}"
                                                           TextWrapping="Wrap"/>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Text="?" FontSize="10" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </Border>
                                </StackPanel>
                            </ui:Button>

                            <!-- Separador visual -->
                            <Border Width="1" Height="20"
                                    Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0"/>

                            <!-- Recomendado: la burbuja "?" va embebida en el contenido
                                 del botón. Click en cualquier parte = SelectRecommended;
                                 hover sobre la burbuja = tooltip con el criterio. La
                                 burbuja es un Border decorativo (no Button), así que el
                                 click se propaga al ui:Button padre sin doble handler. -->
                            <!-- Recomendado: tooltip SOLO en la burbuja "?", no en el botón completo.
                                 PreviewMouseLeftButtonDown en la burbuja evita ejecutar SelectRecommended al clicar "?". -->
                            <ui:Button Appearance="Secondary"
                                       Style="{StaticResource ToolbarButton}"
                                       Padding="14,4,10,4"
                                       Command="{Binding SelectRecommendedCommand}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:T Key=Modules.SelectRecommended}"
                                               VerticalAlignment="Center"/>
                                    <Border Width="16" Height="16"
                                            Margin="9,0,0,0"
                                            CornerRadius="8"
                                            Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            VerticalAlignment="Center"
                                            Cursor="Help"
                                            PreviewMouseLeftButtonDown="OnQuestionMarkPreventClick"
                                            ToolTipService.ShowDuration="30000"
                                            ToolTipService.InitialShowDelay="200">
                                        <Border.ToolTip>
                                            <ToolTip MaxWidth="380" Padding="12,10">
                                                <TextBlock Text="{Binding [Modules.Recommended.Why], Source={x:Static svc:LocalizationService.Instance}}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12"/>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Text="?"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   LineHeight="16"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </Border>
                                </StackPanel>
                            </ui:Button>

                            <ui:Button Appearance="Secondary"
                                       Style="{StaticResource ToolbarButton}"
                                       Content="{loc:T Key=Modules.SelectAll}"
                                       Command="{Binding SelectAllCommand}"/>
                            <ui:Button Appearance="Secondary"
                                       Style="{StaticResource ToolbarButton}"
                                       Margin="0"
                                       Content="{loc:T Key=Modules.DeselectAll}"
                                       Command="{Binding DeselectAllCommand}"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Text="{loc:T Key=Modules.Title}"
                                          FontTypography="TitleLarge"/>
                            <ui:TextBlock Text="{loc:T Key=Modules.Subtitle}"
                                          Opacity="0.65"
                                          TextWrapping="Wrap"
                                          Margin="0,2,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- ── Barra de búsqueda ── -->
                    <Border Margin="24,0,24,10"
                            Padding="10,7"
                            CornerRadius="8"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0"
                                           Symbol="Search24"
                                           FontSize="15"
                                           Opacity="0.5"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalAlignment="Center"
                                     FontSize="13"
                                     Padding="0">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <Setter Property="CaretBrush" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <!-- Placeholder (visible cuando TextBox vacío) -->
                            <TextBlock Grid.Column="1"
                                       Text="{loc:T Key=Search.Placeholder}"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearchActive}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- Botón × para limpiar búsqueda -->
                            <Button Grid.Column="2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="4,2"
                                    Cursor="Hand"
                                    Command="{Binding ClearSearchCommand}"
                                    VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearchActive}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" Opacity="0.6"/>
                            </Button>
                        </Grid>
                    </Border>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                      <Grid>

                        <!-- ── Vista normal (3 columnas + gaming) ── -->
                        <StackPanel MaxWidth="1020" HorizontalAlignment="Center" Margin="16,0,16,20"
                                    Visibility="{Binding IsNormalView, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── Columna FREE (siempre desbloqueada) ── -->
                            <StackPanel Grid.Column="0" Margin="6,0">
                                <Border Padding="10,6"
                                        Margin="0,0,0,10"
                                        CornerRadius="6"
                                        Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:TextBlock Text="{loc:T Key=Modules.Tier.Free}" FontTypography="BodyStrong"/>
                                            <ui:TextBlock Text="{Binding FreeModules.Count, StringFormat=' · {0}'}"
                                                          Opacity="0.6"/>
                                        </StackPanel>
                                        <!-- Siempre desbloqueado: icono de check -->
                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="CheckmarkCircle24"
                                                       FontSize="14"
                                                       Foreground="#FF4CAF50"
                                                       VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding FreeModules}"
                                              ItemTemplate="{StaticResource ModuleCardTemplate}"/>
                            </StackPanel>

                            <!-- ── Columna AVANZADO (bloqueada si tier = Free) ── -->
                            <StackPanel Grid.Column="1" Margin="6,0">
                                <Border Padding="10,6"
                                        Margin="0,0,0,10"
                                        CornerRadius="6"
                                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:TextBlock Text="{loc:T Key=Modules.Tier.Advanced}"
                                                          FontTypography="BodyStrong"
                                                          Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                                            <ui:TextBlock Text="{Binding AdvancedModules.Count, StringFormat=' · {0}'}"
                                                          Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                          Opacity="0.75"/>
                                        </StackPanel>
                                        <!-- Candado visible solo cuando tier = Free -->
                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="LockClosed24"
                                                       FontSize="14"
                                                       Foreground="White"
                                                       Opacity="0.8"
                                                       VerticalAlignment="Center">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserTier}" Value="Free">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                        <!-- Check visible cuando tier >= Avanzado -->
                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="CheckmarkCircle24"
                                                       FontSize="14"
                                                       Foreground="White"
                                                       Opacity="0.8"
                                                       VerticalAlignment="Center">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserTier}" Value="Free">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding AdvancedModules}"
                                              ItemTemplate="{StaticResource ModuleCardTemplate}"/>
                            </StackPanel>

                            <!-- ── Columna PRO (bloqueada si tier ≠ Pro) ── -->
                            <StackPanel Grid.Column="2" Margin="6,0">
                                <Border Padding="10,6"
                                        Margin="0,0,0,10"
                                        CornerRadius="6"
                                        Background="{DynamicResource SystemFillColorCautionBackgroundBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:TextBlock Text="{loc:T Key=Modules.Tier.Pro}" FontTypography="BodyStrong"/>
                                            <ui:TextBlock Text="{Binding ProModules.Count, StringFormat=' · {0}'}"
                                                          Opacity="0.6"/>
                                        </StackPanel>
                                        <!-- Candado visible cuando tier ≠ Pro -->
                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="LockClosed24"
                                                       FontSize="14"
                                                       Foreground="#FFB026FF"
                                                       VerticalAlignment="Center">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserTier}" Value="Pro">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                        <!-- Check visible solo cuando tier = Pro -->
                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="CheckmarkCircle24"
                                                       FontSize="14"
                                                       Foreground="#FFB026FF"
                                                       VerticalAlignment="Center">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserTier}" Value="Pro">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding ProModules}"
                                              ItemTemplate="{StaticResource ModuleCardTemplate}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Extra Pro: Gaming -->
                        <Border Margin="0,18,0,0"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="#3A00C853"
                                Background="#0A0F0A">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header gaming -->
                                <Border Grid.Row="0"
                                        Padding="14,12"
                                        CornerRadius="9,9,0,0"
                                        Background="#1500C853">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icono gaming -->
                                        <ui:SymbolIcon Grid.Column="0"
                                                       Symbol="Games24"
                                                       FontSize="22"
                                                       Foreground="#FF00C853"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,14,0"/>

                                        <!-- Título y descripción -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <ui:TextBlock Text="{loc:T Key=Modules.Extra.Title}"
                                                          FontTypography="BodyStrong"
                                                          Foreground="#FF00C853"/>
                                            <ui:TextBlock Text="{loc:T Key=Modules.Extra.Subtitle}"
                                                          FontTypography="Caption"
                                                          Opacity="0.65"
                                                          TextWrapping="Wrap"
                                                          Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Badge PRO + candado/check -->
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Padding="6,2" CornerRadius="4"
                                                    Background="#1A9D4EDD"
                                                    BorderBrush="#3A9D4EDD"
                                                    BorderThickness="1"
                                                    Margin="0,0,10,0">
                                                <ui:TextBlock Text="PRO"
                                                              FontTypography="Caption"
                                                              Foreground="#FFB026FF"
                                                              FontWeight="Bold"/>
                                            </Border>
                                            <!-- Candado: visible cuando tier ≠ Pro -->
                                            <ui:SymbolIcon Symbol="LockClosed24"
                                                           FontSize="17"
                                                           Foreground="#FF00C853"
                                                           VerticalAlignment="Center">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UserTier}" Value="Pro">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                            <!-- Check: visible solo cuando tier = Pro -->
                                            <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                                           FontSize="17"
                                                           Foreground="#FF00C853"
                                                           VerticalAlignment="Center">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UserTier}" Value="Pro">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Acceso a la ventana modal de selección de juegos -->
                                <Border Grid.Row="1" Margin="14,10,14,14"
                                        Padding="14,12"
                                        CornerRadius="8"
                                        Background="#0F00C853"
                                        BorderBrush="#3A00C853"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <ui:TextBlock Text="{loc:T Key=Gaming.CardTitle}"
                                                          FontTypography="BodyStrong"
                                                          Foreground="#FF00C853"/>
                                            <ui:TextBlock Text="{loc:T Key=Gaming.CardDesc}"
                                                          Opacity="0.7"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"
                                                          Margin="0,3,12,0"/>
                                        </StackPanel>
                                        <ui:Button Grid.Column="1"
                                                   Appearance="Primary"
                                                   VerticalAlignment="Center"
                                                   Padding="14,8"
                                                   Icon="{ui:SymbolIcon Symbol=Games24}"
                                                   Content="{loc:T Key=Gaming.OpenSelector}"
                                                   Command="{Binding OpenGameSelectorCommand}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        </StackPanel>

                        <!-- ── Vista de resultados de búsqueda ── -->
                        <StackPanel MaxWidth="1020" HorizontalAlignment="Center" Margin="16,12,16,20"
                                    Visibility="{Binding IsSearchActive, Converter={StaticResource BoolToVis}}">

                            <!-- Etiqueta: "X resultado(s) para «query»" o "Sin resultados" -->
                            <ui:TextBlock Text="{Binding SearchResultsLabel}"
                                          FontTypography="Caption"
                                          Opacity="0.6"
                                          Margin="4,0,0,10"/>

                            <!-- Lista plana de resultados -->
                            <ItemsControl ItemsSource="{Binding SearchResults}"
                                          ItemTemplate="{StaticResource ModuleCardTemplate}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSearchResults}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>

                            <!-- Sin resultados: panel informativo -->
                            <Border Padding="24,20" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    MinWidth="380">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSearchResults}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="SearchInfo24" FontSize="36"
                                                   Opacity="0.3"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,10"/>
                                    <ui:TextBlock Text="{Binding SearchResultsLabel}"
                                                  FontTypography="BodyStrong"
                                                  Opacity="0.5"
                                                  HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                      </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="24,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock Grid.Column="0"
                                          Text="{Binding StatusMessage}"
                                          VerticalAlignment="Center"
                                          Opacity="0.8"
                                          TextWrapping="Wrap"
                                          MaxHeight="48"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button Appearance="Secondary"
                                           Content="{loc:T Key=Common.Cancel}"
                                           Icon="{ui:SymbolIcon Symbol=Stop24}"
                                           Command="{Binding CancelCommand}"
                                           Margin="0,0,8,0"/>
                                <ui:Button Appearance="Primary"
                                           Content="{loc:T Key=Common.Run}"
                                           Icon="{ui:SymbolIcon Symbol=Play24}"
                                           Command="{Binding RunCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Vista Registro -->
                <Grid Visibility="{Binding IsLogView, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header con título + acciones (Refrescar / Vaciar / Exportar) -->
                    <DockPanel Grid.Row="0" Margin="24,20,24,12">
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <ui:Button Appearance="Secondary"
                                       Style="{StaticResource ToolbarButton}"
                                       Content="{loc:T Key=Log.Refresh}"
                                       Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                                       Command="{Binding RefreshAppLogCommand}"/>
                            <ui:Button Appearance="Secondary"
                                       Style="{StaticResource ToolbarButton}"
                                       Content="{loc:T Key=Log.Export}"
                                       Icon="{ui:SymbolIcon Symbol=ArrowDownload24}"
                                       Command="{Binding ExportAppLogCommand}"/>
                            <ui:Button Appearance="Caution"
                                       Style="{StaticResource ToolbarButton}"
                                       Margin="0"
                                       Content="{loc:T Key=Log.ClearAll}"
                                       Icon="{ui:SymbolIcon Symbol=Delete24}"
                                       Command="{Binding ClearAppLogCommand}"/>
                        </StackPanel>
                        <StackPanel>
                            <ui:TextBlock Text="{loc:T Key=Log.Title}"
                                          FontTypography="TitleLarge"/>
                            <ui:TextBlock Text="{loc:T Key=Log.Subtitle}"
                                          Opacity="0.65"
                                          TextWrapping="Wrap"
                                          Margin="0,2,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- TabControl: Historial (DataGrid persistido) + Salida en directo -->
                    <TabControl Grid.Row="1"
                                Margin="24,0,24,0"
                                Background="Transparent"
                                BorderThickness="0">

                        <!-- TAB 1: Historial interno (persistido en SQLite) -->
                        <TabItem Header="{loc:T Key=Log.Tab.History}">
                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="0">
                                <Grid>
                                    <!-- Cabecera de columnas estilo "tabla" -->
                                    <Grid VerticalAlignment="Top" Height="34"
                                          Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{loc:T Key=Log.Column.Time}"
                                                   Margin="14,0,0,0" VerticalAlignment="Center"
                                                   FontWeight="SemiBold" FontSize="12" Opacity="0.75"/>
                                        <TextBlock Grid.Column="1" Text="{loc:T Key=Log.Column.Level}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold" FontSize="12" Opacity="0.75"/>
                                        <TextBlock Grid.Column="2" Text="{loc:T Key=Log.Column.Category}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold" FontSize="12" Opacity="0.75"/>
                                        <TextBlock Grid.Column="3" Text="{loc:T Key=Log.Column.Message}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold" FontSize="12" Opacity="0.75"/>
                                    </Grid>

                                    <!-- Lista virtualizada de entradas -->
                                    <ScrollViewer Margin="0,34,0,0"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding AppLogEntries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type mdl:LogEntry}">
                                                    <Grid Margin="0,2" Height="36">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Hora local -->
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding TimestampUtc, Converter={StaticResource UtcToLocalTime}}"
                                                                   Margin="14,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   FontFamily="Consolas"
                                                                   FontSize="12"
                                                                   Opacity="0.85"/>

                                                        <!-- Badge de nivel coloreado -->
                                                        <Border Grid.Column="1"
                                                                Background="{Binding Level, Converter={StaticResource LogLevelBrush}}"
                                                                CornerRadius="4"
                                                                Padding="8,2"
                                                                Margin="0,6,8,6"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Level, Converter={StaticResource LogLevelText}}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White"/>
                                                        </Border>

                                                        <!-- Categoría localizada -->
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Category, Converter={StaticResource LogCategoryText}}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="12"
                                                                   Opacity="0.85"/>

                                                        <!-- Mensaje (con tooltip de details si existen) -->
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding Message}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   FontSize="13"
                                                                   Margin="0,0,12,0"
                                                                   ToolTip="{Binding Details}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <!-- Separador sutil entre filas -->
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Margin" Value="0"/>
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Overlay "cargando" -->
                                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            Visibility="{Binding IsLoadingAppLog, Converter={StaticResource BoolToVis}}">
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                            <ui:ProgressRing IsIndeterminate="True"
                                                             Width="22" Height="22"
                                                             Margin="0,0,12,0"/>
                                            <TextBlock Text="{loc:T Key=Log.Loading}"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.85"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Estado vacío (sin entradas) -->
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsAppLogEmpty, Converter={StaticResource BoolToVis}}">
                                        <ui:SymbolIcon Symbol="DocumentText24"
                                                       FontSize="40"
                                                       Opacity="0.35"
                                                       HorizontalAlignment="Center"/>
                                        <TextBlock Text="{loc:T Key=Log.Empty.Title}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,8,0,0"
                                                   Opacity="0.85"/>
                                        <TextBlock Text="{loc:T Key=Log.Empty.Subtitle}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"
                                                   Opacity="0.6"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="320"
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </TabItem>

                        <!-- TAB 2: Salida en directo (stream de progreso de los módulos nativos) -->
                        <TabItem Header="{loc:T Key=Log.Tab.LiveOutput}">
                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <TextBox Text="{Binding OutputLog, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Padding="12"/>
                            </Border>
                        </TabItem>
                    </TabControl>

                    <!-- Pie con StatusMessage + Cancelar / Ejecutar -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="24,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock Grid.Column="0"
                                          Text="{Binding StatusMessage}"
                                          VerticalAlignment="Center"
                                          Opacity="0.8"
                                          TextWrapping="Wrap"
                                          MaxHeight="48"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button Appearance="Secondary"
                                           Content="{loc:T Key=Common.Cancel}"
                                           Icon="{ui:SymbolIcon Symbol=Stop24}"
                                           Command="{Binding CancelCommand}"
                                           Margin="0,0,8,0"/>
                                <ui:Button Appearance="Primary"
                                           Content="{loc:T Key=Common.Run}"
                                           Icon="{ui:SymbolIcon Symbol=Play24}"
                                           Command="{Binding RunCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Vista Especificaciones -->
                <ScrollViewer Visibility="{Binding IsSpecsView, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="860" HorizontalAlignment="Center" Margin="32,24,32,32">
                        <StackPanel>

                            <!-- Header con separación amplia entre título y botón Refrescar -->
                            <DockPanel Margin="0,0,0,22">
                                <ui:Button DockPanel.Dock="Right"
                                           Appearance="Secondary"
                                           Style="{StaticResource ToolbarButton}"
                                           Margin="24,0,0,0"
                                           Content="{loc:T Key=Specs.Refresh}"
                                           Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                                           Command="{Binding LoadSystemInfoCommand}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <ui:TextBlock Text="{loc:T Key=Specs.Title}" FontTypography="TitleLarge"/>
                                    <ui:TextBlock Text="{loc:T Key=Specs.Subtitle}"
                                                  Opacity="0.65"
                                                  TextWrapping="Wrap"
                                                  Margin="0,2,0,0"/>
                                </StackPanel>
                            </DockPanel>

                            <!-- Cargando -->
                            <ui:InfoBar Severity="Informational"
                                        Title="{loc:T Key=Specs.Loading}"
                                        IsClosable="False"
                                        IsOpen="{Binding IsLoadingSpecs}"
                                        Margin="0,0,0,12"/>

                            <!-- Contenido (visible cuando hay datos) -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <!-- Visible por defecto; se oculta sólo si no hay datos -->
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SystemSpecs}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <!-- Fila 1: CPU + RAM -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- CPU -->
                                    <Border Grid.Column="0" Padding="18,16" CornerRadius="10"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="20"
                                                               Foreground="#FF00B8D9"
                                                               Margin="0,0,8,0"/>
                                                <ui:TextBlock Text="{loc:T Key=Specs.CPU}"
                                                              FontTypography="BodyStrong"
                                                              VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ui:TextBlock Text="{Binding SystemSpecs.CpuName}"
                                                          TextWrapping="Wrap"
                                                          Margin="0,0,0,4"/>
                                            <ui:TextBlock Opacity="0.65" FontTypography="Caption">
                                                <ui:TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource LocFormat}" ConverterParameter="Specs.CoresLabel">
                                                        <Binding Path="SystemSpecs.CpuCores"/>
                                                        <Binding Path="SystemSpecs.CpuLogical"/>
                                                    </MultiBinding>
                                                </ui:TextBlock.Text>
                                            </ui:TextBlock>
                                            <ui:TextBlock Text="{Binding SystemSpecs.CpuSpeedMhz, StringFormat='{}{0} MHz'}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- RAM -->
                                    <Border Grid.Column="2" Padding="18,16" CornerRadius="10"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <ui:SymbolIcon Symbol="Memory16" FontSize="20"
                                                               Foreground="#FF9D4EDD"
                                                               Margin="0,0,8,0"/>
                                                <ui:TextBlock Text="{loc:T Key=Specs.RAM}"
                                                              FontTypography="BodyStrong"
                                                              VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ui:TextBlock Opacity="0.9" TextWrapping="Wrap" Margin="0,0,0,4">
                                                <ui:TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource LocFormat}" ConverterParameter="Specs.RamLabel">
                                                        <Binding Path="SystemSpecs.RamTotalGb"/>
                                                        <Binding Path="SystemSpecs.RamAvailableGb"/>
                                                    </MultiBinding>
                                                </ui:TextBlock.Text>
                                            </ui:TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Fila 2: GPU + SO -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- GPU -->
                                    <Border Grid.Column="0" Padding="18,16" CornerRadius="10"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <ui:SymbolIcon Symbol="Tv24" FontSize="20"
                                                               Foreground="#FF00C853"
                                                               Margin="0,0,8,0"/>
                                                <ui:TextBlock Text="{loc:T Key=Specs.GPU}"
                                                              FontTypography="BodyStrong"
                                                              VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ui:TextBlock Text="{Binding SystemSpecs.GpuName}"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- SO -->
                                    <Border Grid.Column="2" Padding="18,16" CornerRadius="10"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <ui:SymbolIcon Symbol="WindowApps24" FontSize="20"
                                                               Foreground="#FF0078D4"
                                                               Margin="0,0,8,0"/>
                                                <ui:TextBlock Text="{loc:T Key=Specs.OS}"
                                                              FontTypography="BodyStrong"
                                                              VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ui:TextBlock Text="{Binding SystemSpecs.OsName}"
                                                          TextWrapping="Wrap"
                                                          Margin="0,0,0,4"/>
                                            <ui:TextBlock Text="{Binding SystemSpecs.OsBuild, StringFormat='Build {0}'}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Almacenamiento (full width, lista de discos) -->
                                <Border Padding="18,16" CornerRadius="10"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <ui:SymbolIcon Symbol="Storage24" FontSize="20"
                                                           Foreground="#FFFF9500"
                                                           Margin="0,0,8,0"/>
                                            <ui:TextBlock Text="{loc:T Key=Specs.Storage}"
                                                          FontTypography="BodyStrong"
                                                          VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding SystemSpecs.Disks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ui:TextBlock Grid.Column="0"
                                                                      Text="{Binding Letter}"
                                                                      FontTypography="BodyStrong"
                                                                      Foreground="#FFFF9500"
                                                                      VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1">
                                                            <ui:TextBlock Text="{Binding Label}"
                                                                          Opacity="0.8"
                                                                          FontTypography="Caption"/>
                                                            <ui:TextBlock Opacity="0.6"
                                                                          FontTypography="Caption">
                                                                <ui:TextBlock.Text>
                                                                    <MultiBinding Converter="{StaticResource LocFormat}" ConverterParameter="Specs.DiskLabel">
                                                                        <Binding Path="TotalGb"/>
                                                                        <Binding Path="FreeGb"/>
                                                                        <Binding Path="FileSystem"/>
                                                                    </MultiBinding>
                                                                </ui:TextBlock.Text>
                                                            </ui:TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- Vista Revertir Cambios -->
                <ScrollViewer Visibility="{Binding IsRestoreView, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="980" HorizontalAlignment="Center" Margin="32,24,32,32">
                        <StackPanel>
                            <!-- Header: título + acciones (Refresh, Revert all) -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <ui:TextBlock Text="{loc:T Key=Restore.Title}"
                                                  FontTypography="TitleLarge"/>
                                    <ui:TextBlock Text="{loc:T Key=Restore.Subtitle}"
                                                  Opacity="0.7"
                                                  TextWrapping="Wrap"
                                                  Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <ui:Button Appearance="Secondary"
                                               Content="{loc:T Key=Restore.Refresh}"
                                               Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                                               Command="{Binding RefreshChangesCommand}"
                                               Margin="0,0,8,0"/>
                                    <ui:Button Appearance="Primary"
                                               Content="{loc:T Key=Restore.RevertAll}"
                                               Icon="{ui:SymbolIcon Symbol=ArrowUndo24}"
                                               Command="{Binding RevertAllChangesCommand}"
                                               IsEnabled="{Binding HasPendingChanges}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Contador -->
                            <ui:TextBlock Margin="0,12,0,12"
                                          Opacity="0.7"
                                          FontTypography="Caption">
                                <Run Text="{Binding PendingChangesCount, Mode=OneWay}"/>
                                <Run Text=" — "/>
                                <Run Text="{loc:T Key=Restore.PendingCount}"/>
                            </ui:TextBlock>

                            <!-- Estado vacío -->
                            <ui:InfoBar Severity="Informational"
                                        Title="{loc:T Key=Restore.Empty.Title}"
                                        Message="{loc:T Key=Restore.Empty.Message}"
                                        IsClosable="False"
                                        IsOpen="True">
                                <ui:InfoBar.Style>
                                    <Style TargetType="ui:InfoBar">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPendingChanges}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:InfoBar.Style>
                            </ui:InfoBar>

                            <!-- Tabla de cambios pendientes -->
                            <Border Margin="0,12,0,0"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding HasPendingChanges, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Cabecera -->
                                    <Grid Grid.Row="0" Height="34"
                                          Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Margin="14,0,0,0"
                                                      VerticalAlignment="Center" FontWeight="SemiBold"
                                                      Text="{loc:T Key=Restore.Column.Module}"/>
                                        <ui:TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                      FontWeight="SemiBold"
                                                      Text="{loc:T Key=Restore.Column.Type}"/>
                                        <ui:TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                      FontWeight="SemiBold"
                                                      Text="{loc:T Key=Restore.Column.Target}"/>
                                        <ui:TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                      FontWeight="SemiBold"
                                                      Text="{loc:T Key=Restore.Column.AppliedAt}"/>
                                    </Grid>

                                    <!-- Filas -->
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding PendingChanges}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="0,0,0,1"
                                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                        Padding="0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="180"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="120"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ui:TextBlock Grid.Column="0" Margin="14,0,0,0"
                                                                      VerticalAlignment="Center"
                                                                      Text="{Binding ModuleName}"
                                                                      TextTrimming="CharacterEllipsis"/>
                                                        <ui:TextBlock Grid.Column="1"
                                                                      VerticalAlignment="Center"
                                                                      Opacity="0.75"
                                                                      Text="{Binding ChangeType, Converter={StaticResource ChangeTypeText}}"/>
                                                        <ui:TextBlock Grid.Column="2"
                                                                      VerticalAlignment="Center"
                                                                      Opacity="0.75"
                                                                      FontFamily="Consolas, Cascadia Mono"
                                                                      FontSize="11"
                                                                      Text="{Binding Target}"
                                                                      TextTrimming="CharacterEllipsis"
                                                                      ToolTip="{Binding Target}"/>
                                                        <ui:TextBlock Grid.Column="3"
                                                                      VerticalAlignment="Center"
                                                                      Opacity="0.75"
                                                                      FontSize="11"
                                                                      Text="{Binding AppliedAtUtc, Converter={StaticResource UtcToLocalTime}, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                                                        <ui:Button Grid.Column="4"
                                                                   Appearance="Secondary"
                                                                   Content="{loc:T Key=Restore.RevertOne}"
                                                                   Icon="{ui:SymbolIcon Symbol=ArrowUndo24}"
                                                                   Margin="0,0,10,0"
                                                                   Command="{Binding DataContext.RevertChangeCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                                   CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- Vista Ajustes -->
                <ScrollViewer Visibility="{Binding IsSettingsView, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="860" HorizontalAlignment="Center" Margin="32,24,32,32">
                        <StackPanel>
                            <ui:TextBlock Text="{loc:T Key=Settings.Title}" FontTypography="TitleLarge"/>
                            <ui:TextBlock Text="{loc:T Key=Settings.Subtitle}"
                                          Opacity="0.65"
                                          TextWrapping="Wrap"
                                          Margin="0,2,0,18"/>

                            <!-- Idioma -->
                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <ui:TextBlock Text="{loc:T Key=Settings.Language.Title}"
                                                      FontTypography="Subtitle"
                                                      Margin="0,0,0,4"/>
                                        <ui:TextBlock Text="{loc:T Key=Settings.Language.Description}"
                                                      Opacity="0.7"
                                                      TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <!-- Selector de idioma:
                                           - Windows no incluye una fuente con glifos de
                                             banderas (Segoe UI Emoji solo combina los pares
                                             "regional indicator" en mayúsculas; el resultado
                                             son dos letras, no una bandera).
                                           - En lugar de luchar contra el SO, mostramos el
                                             código ISO en un chip compacto + el nombre
                                             nativo. Es lo mismo que hace Settings de Windows
                                             y queda limpio y reconocible.
                                           - MaxDropDownHeight obliga al ScrollViewer interno
                                             del ComboBox a aparecer cuando hay 30 idiomas. -->
                                    <ComboBox Grid.Column="1"
                                              Width="220"
                                              VerticalAlignment="Center"
                                              MaxDropDownHeight="220"
                                              ItemsSource="{Binding AvailableLanguages}"
                                              SelectedValuePath="Code"
                                              SelectedValue="{Binding CurrentLanguage, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- Bandera PNG cargada desde flagcdn.com (20×15 px) -->
                                                    <Image Source="{Binding FlagImageUrl}"
                                                           Width="20" Height="15"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,9,0"
                                                           SnapsToDevicePixels="True"/>
                                                    <TextBlock Text="{Binding NativeName}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Tema visual — selector de paletas con candado por plan -->
                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:T Key=Settings.Theme.Title}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,4"/>
                                    <ui:TextBlock Text="{loc:T Key=Settings.Theme.Description}"
                                                  Opacity="0.7"
                                                  TextWrapping="Wrap"
                                                  Margin="0,0,0,14"/>
                                    <ItemsControl ItemsSource="{Binding ThemeItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="170" Height="120"
                                                        Margin="0,0,10,10"
                                                        Padding="0"
                                                        BorderThickness="2"
                                                        Cursor="Hand"
                                                        HorizontalContentAlignment="Stretch"
                                                        VerticalContentAlignment="Stretch"
                                                        Command="{Binding DataContext.SelectThemeCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                                            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsUnlocked}" Value="False">
                                                                    <Setter Property="Opacity" Value="0.55"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- Bloque superior: 3 muestras de color en gradiente vertical -->
                                                        <Grid Grid.Row="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding PreviewColor1}"/>
                                                                </Border.Background>
                                                            </Border>
                                                            <Border Grid.Column="1">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding PreviewColor2}"/>
                                                                </Border.Background>
                                                            </Border>
                                                            <Border Grid.Column="2">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding PreviewColor3}"/>
                                                                </Border.Background>
                                                            </Border>

                                                            <!-- Badge "Activo" en esquina superior derecha -->
                                                            <Border HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Margin="0,6,6,0"
                                                                    Padding="6,2"
                                                                    CornerRadius="4"
                                                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                                    Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                                                <ui:TextBlock Text="{loc:T Key=Settings.Theme.Active}"
                                                                              FontTypography="Caption"
                                                                              FontWeight="Bold"
                                                                              Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                                                            </Border>

                                                            <!-- Candado en el centro si está bloqueado -->
                                                            <ui:SymbolIcon Symbol="LockClosed24"
                                                                           Filled="True"
                                                                           FontSize="32"
                                                                           Foreground="White"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center">
                                                                <ui:SymbolIcon.Visibility>
                                                                    <Binding Path="IsUnlocked" Converter="{StaticResource InverseBoolToVis}"/>
                                                                </ui:SymbolIcon.Visibility>
                                                            </ui:SymbolIcon>
                                                        </Grid>

                                                        <!-- Bloque inferior: nombre + hint del plan si bloqueado -->
                                                        <StackPanel Grid.Row="1" Margin="10,6,10,8">
                                                            <ui:TextBlock Text="{Binding NameKey, Converter={StaticResource Loc}}"
                                                                          FontTypography="BodyStrong"/>
                                                            <ui:TextBlock Text="{loc:T Key=Settings.Theme.LockedHint}"
                                                                          FontTypography="Caption"
                                                                          Opacity="0.7"
                                                                          Visibility="{Binding IsUnlocked, Converter={StaticResource InverseBoolToVis}}"/>
                                                            <ui:TextBlock Text="{Binding DescriptionKey, Converter={StaticResource Loc}}"
                                                                          FontTypography="Caption"
                                                                          Opacity="0.6"
                                                                          Visibility="{Binding IsUnlocked, Converter={StaticResource BoolToVis}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Licencia (HWID + activación) -->
                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:T Key=License.Section.Title}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,4"/>
                                    <ui:TextBlock Text="{loc:T Key=License.Section.Description}"
                                                  Opacity="0.7"
                                                  TextWrapping="Wrap"
                                                  Margin="0,0,0,12"/>

                                    <!-- Tier actual -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0"
                                                      Text="{loc:T Key=License.CurrentTier.Label}"
                                                      VerticalAlignment="Center"/>
                                        <Border Grid.Column="1"
                                                Padding="10,4" CornerRadius="6"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}">
                                            <ui:TextBlock Text="{Binding UserTier}"
                                                          Foreground="White"
                                                          FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>

                                    <!-- HWID con botón Copiar -->
                                    <ui:TextBlock Text="{loc:T Key=License.Hwid.Label}"
                                                  FontWeight="SemiBold"
                                                  Margin="0,4,0,4"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding HardwareId, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 FontFamily="Consolas"
                                                 VerticalAlignment="Center"
                                                 Padding="8,6"
                                                 Margin="0,0,8,0"/>
                                        <ui:Button Grid.Column="1"
                                                   Content="{loc:T Key=License.Hwid.Copy}"
                                                   Command="{Binding CopyHardwareIdCommand}"
                                                   Appearance="Secondary"/>
                                    </Grid>

                                    <!-- TextBox de clave + botón Activar -->
                                    <ui:TextBlock Text="{loc:T Key=License.Activation.Label}"
                                                  FontWeight="SemiBold"
                                                  Margin="0,4,0,4"/>
                                    <ui:TextBlock Text="{loc:T Key=License.Activation.Help}"
                                                  Opacity="0.55"
                                                  FontTypography="Caption"
                                                  TextWrapping="Wrap"
                                                  Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding ActivationKeyInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="False"
                                             FontFamily="Consolas"
                                             FontSize="11"
                                             TextWrapping="Wrap"
                                             Height="80"
                                             VerticalScrollBarVisibility="Auto"
                                             Padding="8,6"
                                             Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                                        <ui:Button Content="{loc:T Key=License.Activation.Activate}"
                                                   Command="{Binding ActivateLicenseCommand}"
                                                   Appearance="Primary"
                                                   Margin="0,0,8,0"/>
                                        <ui:Button Content="{loc:T Key=License.Activation.Deactivate}"
                                                   Command="{Binding DeactivateLicenseCommand}"
                                                   Appearance="Secondary"/>
                                    </StackPanel>
                                    <ui:TextBlock Text="{Binding LicenseStatusMessage}"
                                                  TextWrapping="Wrap"
                                                  Opacity="0.85"
                                                  FontTypography="Caption"/>
                                </StackPanel>
                            </Border>

                            <!-- Comportamiento -->
                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:T Key=Settings.Behavior.Title}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,8"/>

                                    <Grid Margin="0,6,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Settings.AutoSelect.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Settings.AutoSelect.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ui:ToggleSwitch Grid.Column="1"
                                                         IsChecked="{Binding AutoSelectRecommended, Mode=TwoWay}"/>
                                    </Grid>

                                    <Grid Margin="0,6,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Settings.JumpToLog.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Settings.JumpToLog.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ui:ToggleSwitch Grid.Column="1"
                                                         IsChecked="{Binding JumpToLogOnRun, Mode=TwoWay}"/>
                                    </Grid>

                                    <Grid Margin="0,6,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Settings.WarnNonReversible.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Settings.WarnNonReversible.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ui:ToggleSwitch Grid.Column="1"
                                                         IsChecked="{Binding WarnBeforeNonReversible, Mode=TwoWay}"/>
                                    </Grid>

                                    <Grid Margin="0,6,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Settings.NotifyOnFinish.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Settings.NotifyOnFinish.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ui:ToggleSwitch Grid.Column="1"
                                                         IsChecked="{Binding NotifyOnFinish, Mode=TwoWay}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Card: Punto de restauración del sistema -->
                            <Border Padding="20,18" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,16,0,0">
                                <StackPanel>
                                    <!-- Encabezado con icono de escudo -->
                                    <DockPanel Margin="0,0,0,12">
                                        <ui:SymbolIcon DockPanel.Dock="Left"
                                                        Symbol="Shield24"
                                                        FontSize="20"
                                                        Margin="0,0,10,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="#FF00C853"/>
                                        <StackPanel>
                                            <ui:TextBlock Text="{loc:T Key=Settings.RestorePoint.Title}"
                                                          FontTypography="BodyStrong"/>
                                            <ui:TextBlock Text="{loc:T Key=Settings.RestorePoint.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"
                                                          Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- El toggle "crear automáticamente" se eliminó porque
                                         ahora la app SIEMPRE pregunta antes de ejecutar
                                         (sí/no/cancelar). La preferencia persistida
                                         CreateRestorePointBeforeRun sigue existiendo en
                                         AppSettings por compatibilidad pero ya no se
                                         expone en la UI. -->
                                    <ui:InfoBar Severity="Informational"
                                                Title="{loc:T Key=Settings.RestorePoint.AlwaysAsksTitle}"
                                                Message="{loc:T Key=Settings.RestorePoint.AlwaysAsksMessage}"
                                                IsClosable="False"
                                                IsOpen="True"
                                                Margin="0,0,0,12"/>

                                    <!-- Botón manual + mensaje de estado -->
                                    <DockPanel>
                                        <ui:Button DockPanel.Dock="Left"
                                                   Appearance="Secondary"
                                                   Content="{loc:T Key=Settings.RestorePoint.CreateNow}"
                                                   Icon="{ui:SymbolIcon Symbol=Shield24}"
                                                   Command="{Binding CreateRestorePointCommand}"
                                                   Margin="0,0,12,0"/>
                                        <!-- Spinner mientras se crea -->
                                        <ui:ProgressRing IsIndeterminate="True"
                                                         Width="18" Height="18"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center"
                                                         Visibility="{Binding IsCreatingRestorePoint, Converter={StaticResource BoolToVis}}"/>
                                        <!-- Resultado del último intento -->
                                        <ui:TextBlock Text="{Binding RestorePointStatusMessage}"
                                                      VerticalAlignment="Center"
                                                      Opacity="0.75"
                                                      TextWrapping="Wrap"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,12,0,0">
                                <ui:Button Appearance="Secondary"
                                           Content="{loc:T Key=Settings.Reset}"
                                           Icon="{ui:SymbolIcon Symbol=ArrowReset24}"
                                           Command="{Binding ResetSettingsCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- Vista Actualizaciones -->
                <ScrollViewer Visibility="{Binding IsUpdatesView, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="780" HorizontalAlignment="Center" Margin="32,24,32,32">
                        <StackPanel>
                            <ui:TextBlock Text="{loc:T Key=Updates.Title}" FontTypography="TitleLarge"/>
                            <ui:TextBlock Text="{loc:T Key=Updates.Subtitle}"
                                          Opacity="0.65"
                                          TextWrapping="Wrap"
                                          Margin="0,2,0,18"/>

                            <!-- Tarjeta: versión actual + botón buscar -->
                            <Border Padding="20,18" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <ui:TextBlock Text="{loc:T Key=Updates.InstalledVersion}"
                                                      FontTypography="Caption"
                                                      Opacity="0.6"/>
                                        <ui:TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                                                      FontTypography="TitleLarge"
                                                      Margin="0,2,0,4"/>
                                        <ui:TextBlock Text="{Binding LastUpdateCheckLabel}"
                                                      Opacity="0.55"
                                                      FontTypography="Caption"/>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1"
                                               Appearance="Primary"
                                               Content="{loc:T Key=Updates.CheckForUpdates}"
                                               Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                                               Command="{Binding CheckForUpdatesCommand}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Banner: actualización disponible (visible solo cuando hay update) -->
                            <Border Padding="20,16" CornerRadius="10"
                                    Margin="0,0,0,12"
                                    Visibility="{Binding HasAvailableUpdate, Converter={StaticResource BoolToVis}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}"/>
                                        <Setter Property="BorderBrush"
                                                Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                                Margin="0,0,16,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                                           FontSize="16"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center"/>
                                            <ui:TextBlock Text="{loc:T Key=Updates.NewVersionAvailable}"
                                                          FontTypography="BodyStrong"
                                                          VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ui:TextBlock Text="{Binding AvailableUpdateVersionLabel}"
                                                      Opacity="0.85"
                                                      Margin="0,0,0,8"/>
                                        <ProgressBar Value="{Binding UpdateDownloadProgress}"
                                                     Maximum="100"
                                                     Height="4"/>
                                        <ui:TextBlock Text="{Binding UpdateDownloadProgress, StringFormat='{}{0}%'}"
                                                      FontTypography="Caption"
                                                      Opacity="0.65"
                                                      Margin="0,4,0,0"
                                                      Visibility="{Binding HasAvailableUpdate, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1"
                                               Appearance="Primary"
                                               Content="{loc:T Key=Updates.UpdateNow}"
                                               Icon="{ui:SymbolIcon Symbol=ArrowDownload24}"
                                               Command="{Binding ApplyUpdateCommand}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Preferencias -->
                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:T Key=Updates.Preferences}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,10"/>

                                    <Grid Margin="0,4,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Updates.AutoUpdate.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Updates.AutoUpdate.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ui:ToggleSwitch Grid.Column="1"
                                                         IsChecked="{Binding AutoUpdateEnabled, Mode=TwoWay}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{loc:T Key=Updates.Channel.Title}"/>
                                            <ui:TextBlock Text="{loc:T Key=Updates.Channel.Desc}"
                                                          Opacity="0.55"
                                                          FontTypography="Caption"
                                                          TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  Width="140"
                                                  VerticalAlignment="Center"
                                                  ItemsSource="{Binding AvailableChannels}"
                                                  SelectedItem="{Binding UpdateChannel, Mode=TwoWay}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Nota informativa sobre cómo se entregan las actualizaciones -->
                            <ui:InfoBar Severity="Informational"
                                        Title="{loc:T Key=Updates.HowItWorks.Title}"
                                        Message="{loc:T Key=Updates.HowItWorks.Message}"
                                        IsClosable="False"
                                        IsOpen="True"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- Vista Acerca De -->
                <ScrollViewer Visibility="{Binding IsAboutView, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Grid MaxWidth="860" HorizontalAlignment="Center" Margin="32,28,32,32">
                        <StackPanel>

                            <Border Padding="28,28" CornerRadius="14"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,18">
                                <StackPanel HorizontalAlignment="Center">
                                    <Image Source="pack://application:,,,/Assets/AppIcon.png"
                                           Width="180" Height="180"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           SnapsToDevicePixels="True"
                                           UseLayoutRounding="True"/>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,14,0,0">
                                        <Border Padding="8,3" CornerRadius="4"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                Margin="0,0,6,0">
                                            <ui:TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                                                          Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                          FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,3" CornerRadius="4"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="{loc:T Key=About.RequiresAdmin}"
                                                          FontTypography="Caption"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Botón "Reportar un fallo" — mailto pre-rellenado -->
                                    <StackPanel HorizontalAlignment="Center" Margin="0,18,0,0">
                                        <ui:Button Appearance="Secondary"
                                                   Content="{loc:T Key=BugReport.Button}"
                                                   Icon="{ui:SymbolIcon Symbol=Mail24}"
                                                   Command="{Binding ReportBugCommand}"
                                                   HorizontalAlignment="Center"/>
                                        <ui:TextBlock Text="{loc:T Key=BugReport.Subtitle}"
                                                      Opacity="0.6"
                                                      FontTypography="Caption"
                                                      HorizontalAlignment="Center"
                                                      Margin="0,6,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:T Key=About.Project.Title}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,6"/>
                                    <ui:TextBlock Text="{loc:T Key=About.Project.Line1}"
                                                  TextWrapping="Wrap" Opacity="0.85"/>
                                    <ui:TextBlock Text="{loc:T Key=About.Project.Line2}"
                                                  TextWrapping="Wrap" Opacity="0.85"
                                                  Margin="0,4,0,0"/>
                                    <ui:TextBlock Text="{loc:T Key=About.Project.Line3}"
                                                  TextWrapping="Wrap" Opacity="0.85"
                                                  Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{Binding ChangelogTitle}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,8"/>
                                    <StackPanel Margin="0,2,0,2">
                                        <ui:TextBlock Text="{loc:T Key=About.Changelog.Item1}"/>
                                        <ui:TextBlock Text="{loc:T Key=About.Changelog.Item2}" TextWrapping="Wrap"/>
                                        <ui:TextBlock Text="{loc:T Key=About.Changelog.Item3}"/>
                                        <ui:TextBlock Text="{loc:T Key=About.Changelog.Item4}"/>
                                        <ui:TextBlock Text="{loc:T Key=About.Changelog.Item5}" TextWrapping="Wrap"/>
                                        <ui:TextBlock Text="{loc:T Key=About.Changelog.Item6}"/>
                                        <ui:TextBlock Text="{loc:T Key=About.Changelog.Item7}"/>
                                        <ui:TextBlock Text="{loc:T Key=About.Changelog.Item8}" TextWrapping="Wrap"/>
                                        <ui:TextBlock Text="{loc:T Key=About.Changelog.Item9}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:T Key=About.Credits.Title}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="{loc:T Key=About.Credits.Design}" Opacity="0.6"/>
                                        <ui:TextBlock Grid.Column="1" Text="Sr. Dexter"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="{loc:T Key=About.Credits.Development}" Opacity="0.6"/>
                                        <ui:TextBlock Grid.Column="1" Text="Sr. Dexter · DexSuite Performance Series"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="{loc:T Key=About.Credits.GamingModule}" Opacity="0.6"/>
                                        <ui:TextBlock Grid.Column="1" Text="{loc:T Key=About.Credits.GamingModuleAuthor}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:T Key=About.Stack.Title}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,10"/>
                                    <WrapPanel>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text=".NET 8" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="C# 12" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="WPF" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="Wpf.Ui (Lepoco)" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="CommunityToolkit.Mvvm" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="EF Core SQLite" FontTypography="Caption"/>
                                        </Border>
                                        <Border Padding="8,4" CornerRadius="4" Margin="0,0,6,6"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ui:TextBlock Text="Serilog" FontTypography="Caption"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Padding="20,16" CornerRadius="10"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <ui:TextBlock Text="{loc:T Key=About.Utilities.Title}"
                                                  FontTypography="Subtitle"
                                                  Margin="0,0,0,10"/>
                                    <WrapPanel>
                                        <ui:Button Appearance="Secondary"
                                                   Content="{loc:T Key=About.Utilities.OpenLogs}"
                                                   Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                                                   Command="{Binding OpenLogsFolderCommand}"
                                                   Margin="0,0,8,8"/>
                                        <ui:Button Appearance="Secondary"
                                                   Content="{loc:T Key=Updates.CheckForUpdates}"
                                                   Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                                                   Command="{Binding CheckForUpdatesCommand}"
                                                   Margin="0,0,8,8"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <ui:TextBlock Text="{loc:T Key=About.Footer}"
                                          Opacity="0.5"
                                          FontTypography="Caption"
                                          HorizontalAlignment="Center"
                                          Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
