<ui:FluentWindow
    x:Class="DexSuite.App.GameSelectorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:loc="clr-namespace:DexSuite.App.Markup"
    xmlns:svc="clr-namespace:DexSuite.App.Services"
    Title="DexSuite — Optimización de videojuegos"
    Width="780"
    Height="600"
    MinWidth="640"
    MinHeight="480"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="DexSuite — Gaming"/>

        <!-- Cabecera con título y subtítulo -->
        <StackPanel Grid.Row="1" Margin="32,18,32,12">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Games24" FontSize="26"
                               Foreground="#FF00C853"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                <ui:TextBlock Text="{loc:T Key=Gaming.SelectorTitle}"
                              FontTypography="TitleLarge"
                              VerticalAlignment="Center"/>
            </StackPanel>
            <ui:TextBlock Text="{loc:T Key=Gaming.SelectorSubtitle}"
                          Opacity="0.65"
                          TextWrapping="Wrap"
                          Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Lista de juegos: cards con nombre, subtítulo y selector de variante -->
        <ScrollViewer Grid.Row="2"
                      Margin="24,0,24,12"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Games}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="220" Height="140"
                                Margin="0,0,12,12"
                                Padding="14,12"
                                CornerRadius="10"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header: nombre + icono gaming -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Games24"
                                                   FontSize="16"
                                                   Foreground="#FF00C853"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                    <ui:TextBlock Text="{Binding Name}"
                                                  FontTypography="BodyStrong"
                                                  VerticalAlignment="Center"/>
                                </StackPanel>

                                <ui:TextBlock Grid.Row="1"
                                              Text="{Binding Subtitle}"
                                              Opacity="0.6"
                                              FontTypography="Caption"
                                              TextWrapping="Wrap"
                                              VerticalAlignment="Center"
                                              Margin="0,8,0,8"/>

                                <!-- Acción:
                                       - Si hay >1 variante (Battlefield, CoD, Splitgate),
                                         se muestra el ComboBox para que el usuario elija
                                         la versión + botón Optimizar a la derecha.
                                       - Si solo hay una variante, se muestra únicamente
                                         el botón Optimizar a lo ancho — no tiene sentido
                                         repetir el nombre del juego en un desplegable. -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding Variants}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedItem="{Binding SelectedVariant, Mode=TwoWay}"
                                              Margin="0,0,6,0"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding HasMultipleVariants, Converter={StaticResource BoolToVis}}"/>
                                    <ui:Button Grid.Column="1"
                                               Appearance="Primary"
                                               Icon="{ui:SymbolIcon Symbol=Play24}"
                                               Content="{loc:T Key=Gaming.OptimizeButton}"
                                               Command="{Binding DataContext.OptimizeCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                               CommandParameter="{Binding}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer con Cerrar -->
        <Border Grid.Row="3"
                Padding="24,12"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <ui:TextBlock DockPanel.Dock="Left"
                              Text="{loc:T Key=Gaming.FooterNote}"
                              Opacity="0.6"
                              FontTypography="Caption"
                              TextWrapping="Wrap"
                              VerticalAlignment="Center"
                              MaxWidth="500"/>
                <ui:Button HorizontalAlignment="Right"
                           Appearance="Secondary"
                           Content="{loc:T Key=Common.Close}"
                           Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                           Click="OnCloseClicked"/>
            </DockPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
