<ui:FluentWindow
    x:Class="DexSuite.App.GameSelectorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:loc="clr-namespace:DexSuite.App.Markup"
    xmlns:svc="clr-namespace:DexSuite.App.Services"
    Title="DexSuite — Optimización de videojuegos"
    Width="780"
    Height="900"
    MinWidth="640"
    MinHeight="720"
    UseLayoutRounding="True"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="DexSuite — Gaming"/>

        <!-- Cabecera con título y subtítulo -->
        <StackPanel Grid.Row="1" Margin="32,18,32,12">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Games24" FontSize="26"
                               Foreground="#FF00C853"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                <ui:TextBlock Text="{loc:T Key=Gaming.SelectorTitle}"
                              FontTypography="TitleLarge"
                              VerticalAlignment="Center"/>
            </StackPanel>
            <ui:TextBlock Text="{loc:T Key=Gaming.SelectorSubtitle}"
                          Opacity="0.65"
                          TextWrapping="Wrap"
                          Margin="0,4,0,0"/>

            <!-- Buscador: filtra la lista en tiempo real por nombre de juego -->
            <ui:TextBox Margin="0,12,0,0"
                        Icon="{ui:SymbolIcon Symbol=Search24}"
                        PlaceholderText="{loc:T Key=Gaming.SearchPlaceholder}"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
        </StackPanel>

        <!-- Lista de juegos (modo lista, fila horizontal): icono + nombre/subtítulo,
             tick de aplicado, selector de variante y botón Optimizar. -->
        <ListBox Grid.Row="2"
                 Margin="24,0,24,12"
                 ItemsSource="{Binding GamesView}"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="Focusable" Value="False"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="14,10"
                            CornerRadius="10"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icono -->
                            <ui:SymbolIcon Grid.Column="0"
                                           Symbol="Games24"
                                           FontSize="20"
                                           Foreground="#FF00C853"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>

                            <!-- Nombre -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <ui:TextBlock Text="{Binding Name}" FontTypography="BodyStrong"/>
                            </StackPanel>

                            <!-- Tick de configuración aplicada -->
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="8,0,12,0"
                                        Visibility="{Binding IsConfigApplied, Converter={StaticResource BoolToVis}}">
                                <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                               FontSize="18"
                                               Foreground="#FF00C853"
                                               VerticalAlignment="Center"/>
                                <ui:TextBlock Text="{loc:T Key=Gaming.Applied}"
                                              Foreground="#FF00C853"
                                              FontTypography="Caption"
                                              VerticalAlignment="Center"
                                              Margin="5,0,0,0"/>
                            </StackPanel>

                            <!-- Selector de variante (solo si hay más de una) -->
                            <ComboBox Grid.Column="3"
                                      MinWidth="150"
                                      ItemsSource="{Binding Variants}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedVariant, Mode=TwoWay}"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding HasMultipleVariants, Converter={StaticResource BoolToVis}}"/>

                            <!-- Botón Revertir (solo cuando ya se aplicó) -->
                            <ui:Button Grid.Column="4"
                                       Appearance="Secondary"
                                       Icon="{ui:SymbolIcon Symbol=ArrowUndo24}"
                                       Content="{loc:T Key=Gaming.Revert.Button}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Visibility="{Binding IsConfigApplied, Converter={StaticResource BoolToVis}}"
                                       Command="{Binding DataContext.RevertGameCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                       CommandParameter="{Binding}"/>

                            <!-- Botón Optimizar -->
                            <ui:Button Grid.Column="5"
                                       Appearance="Primary"
                                       Icon="{ui:SymbolIcon Symbol=Play24}"
                                       Content="{loc:T Key=Gaming.OptimizeButton}"
                                       VerticalAlignment="Center"
                                       Command="{Binding DataContext.OptimizeCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                       CommandParameter="{Binding}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer con Cerrar -->
        <Border Grid.Row="3"
                Padding="24,12"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <ui:TextBlock DockPanel.Dock="Left"
                              Text="{loc:T Key=Gaming.FooterNote}"
                              Opacity="0.6"
                              FontTypography="Caption"
                              TextWrapping="Wrap"
                              VerticalAlignment="Center"
                              MaxWidth="500"/>
                <ui:Button HorizontalAlignment="Right"
                           Appearance="Secondary"
                           Content="{loc:T Key=Common.Close}"
                           Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                           Click="OnCloseClicked"/>
            </DockPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
