<!-- =====================================================================
     ZERO LAG — Paleta ultraminimalista monocroma.
     Negro absoluto + escala de grises + acento blanco hielo.
     Eliminación total de ruido visual para concentrar la atención.
===================================================================== -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Z0.Bg.Window">#FF050505</Color>
    <Color x:Key="Z0.Bg.Sidebar">#FF0C0C0C</Color>
    <Color x:Key="Z0.Bg.Card">#FF131313</Color>
    <Color x:Key="Z0.Bg.CardHover">#FF1C1C1C</Color>
    <Color x:Key="Z0.Bg.Subtle">#FF222222</Color>

    <Color x:Key="Z0.Stroke.Default">#FF2A2A2A</Color>
    <Color x:Key="Z0.Stroke.Subtle">#FF1A1A1A</Color>

    <Color x:Key="Z0.Text.Primary">#FFF2F2F2</Color>
    <Color x:Key="Z0.Text.Secondary">#FF9E9E9E</Color>
    <Color x:Key="Z0.Text.Tertiary">#FF606060</Color>
    <Color x:Key="Z0.Text.OnAccent">#FF050505</Color>

    <Color x:Key="Z0.Accent">#FFEAF6FF</Color>
    <Color x:Key="Z0.AccentBright">#FFFFFFFF</Color>
    <Color x:Key="Z0.AccentDim">#FFB0BBC4</Color>

    <Color x:Key="Z0.Success">#FF7CFFB2</Color>
    <Color x:Key="Z0.SuccessBg">#337CFFB2</Color>
    <Color x:Key="Z0.Caution">#FFFFD580</Color>
    <Color x:Key="Z0.CautionBg">#33FFD580</Color>
    <Color x:Key="Z0.Critical">#FFFF8A8A</Color>
    <Color x:Key="Z0.CriticalBg">#33FF8A8A</Color>

    <Color x:Key="Theme.Preview.Color1">#FF0C0C0C</Color>
    <Color x:Key="Theme.Preview.Color2">#FF606060</Color>
    <Color x:Key="Theme.Preview.Color3">#FFFFFFFF</Color>

    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource Z0.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource Z0.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource Z0.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="{StaticResource Z0.Bg.Card}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{StaticResource Z0.Bg.CardHover}"/>

    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{StaticResource Z0.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource Z0.Bg.Card}"/>
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{StaticResource Z0.Bg.CardHover}"/>

    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource Z0.Bg.Card}"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource Z0.Bg.CardHover}"/>
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource Z0.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{StaticResource Z0.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{StaticResource Z0.Bg.CardHover}"/>

    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{StaticResource Z0.Bg.Subtle}"/>
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{StaticResource Z0.Bg.Card}"/>
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="Transparent"/>

    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource Z0.Stroke.Default}"/>
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource Z0.Stroke.Subtle}"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentDefaultBrush" Color="#33050505"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentSecondaryBrush" Color="#22050505"/>
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{StaticResource Z0.Stroke.Default}"/>

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource Z0.Accent}"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource Z0.AccentBright}"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource Z0.AccentDim}"/>
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="{StaticResource Z0.Bg.Subtle}"/>
    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="{StaticResource Z0.Accent}"/>
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource Z0.Accent}"/>
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource Z0.AccentBright}"/>
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{StaticResource Z0.AccentDim}"/>

    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource Z0.Text.Primary}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource Z0.Text.Secondary}"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource Z0.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource Z0.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="{StaticResource Z0.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="{StaticResource Z0.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="{StaticResource Z0.Text.OnAccent}"/>

    <SolidColorBrush x:Key="AccentControlElevationBorderBrush" Color="{StaticResource Z0.Accent}"/>
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{StaticResource Z0.Stroke.Default}"/>
    <SolidColorBrush x:Key="CircleElevationBorderBrush" Color="{StaticResource Z0.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource Z0.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderFocusedBrush" Color="{StaticResource Z0.Accent}"/>

    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource Z0.Success}"/>
    <SolidColorBrush x:Key="SystemFillColorSuccessBackgroundBrush" Color="{StaticResource Z0.SuccessBg}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{StaticResource Z0.Caution}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBackgroundBrush" Color="{StaticResource Z0.CautionBg}"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource Z0.Critical}"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBackgroundBrush" Color="{StaticResource Z0.CriticalBg}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="{StaticResource Z0.Accent}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBackgroundBrush" Color="#33EAF6FF"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="{StaticResource Z0.Text.Secondary}"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBackgroundBrush" Color="{StaticResource Z0.Bg.Subtle}"/>

</ResourceDictionary>
