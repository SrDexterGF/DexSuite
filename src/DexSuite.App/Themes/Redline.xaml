<!-- =====================================================================
     REDLINE — Paleta gaming carrera (rojo sangre + negro profundo).
     Inspirada en cockpits de coches deportivos y dashboards de telemetría.
     Saturación atenuada en bases, neón en acentos.
===================================================================== -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Paleta base ============ -->
    <Color x:Key="Rdl.Bg.Window">#FF0A0606</Color>
    <Color x:Key="Rdl.Bg.Sidebar">#FF130808</Color>
    <Color x:Key="Rdl.Bg.Card">#FF1A0E0E</Color>
    <Color x:Key="Rdl.Bg.CardHover">#FF231414</Color>
    <Color x:Key="Rdl.Bg.Subtle">#FF2A1818</Color>

    <Color x:Key="Rdl.Stroke.Default">#FF3D1F1F</Color>
    <Color x:Key="Rdl.Stroke.Subtle">#FF291515</Color>

    <Color x:Key="Rdl.Text.Primary">#FFF8E8E8</Color>
    <Color x:Key="Rdl.Text.Secondary">#FFA8898C</Color>
    <Color x:Key="Rdl.Text.Tertiary">#FF7A6062</Color>
    <Color x:Key="Rdl.Text.OnAccent">#FFFFFFFF</Color>

    <!-- Rojo carrera -->
    <Color x:Key="Rdl.Red">#FFE63946</Color>
    <Color x:Key="Rdl.RedBright">#FFFF1744</Color>
    <Color x:Key="Rdl.RedDim">#FF8B0000</Color>

    <Color x:Key="Rdl.Success">#FF00D9A0</Color>
    <Color x:Key="Rdl.SuccessBg">#3300D9A0</Color>
    <Color x:Key="Rdl.Caution">#FFFFB800</Color>
    <Color x:Key="Rdl.CautionBg">#33FFB800</Color>
    <Color x:Key="Rdl.Critical">#FFFF5470</Color>
    <Color x:Key="Rdl.CriticalBg">#33FF5470</Color>

    <!-- Preview swatches (sidebar / card / accent) -->
    <Color x:Key="Theme.Preview.Color1">#FF130808</Color>
    <Color x:Key="Theme.Preview.Color2">#FFE63946</Color>
    <Color x:Key="Theme.Preview.Color3">#FFFF1744</Color>

    <!-- ============ Overrides Wpf.Ui ============ -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource Rdl.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource Rdl.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource Rdl.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="{StaticResource Rdl.Bg.Card}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{StaticResource Rdl.Bg.CardHover}"/>

    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{StaticResource Rdl.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource Rdl.Bg.Card}"/>
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{StaticResource Rdl.Bg.CardHover}"/>

    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource Rdl.Bg.Card}"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource Rdl.Bg.CardHover}"/>
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource Rdl.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{StaticResource Rdl.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{StaticResource Rdl.Bg.CardHover}"/>

    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{StaticResource Rdl.Bg.Subtle}"/>
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{StaticResource Rdl.Bg.Card}"/>
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="Transparent"/>

    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource Rdl.Stroke.Default}"/>
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource Rdl.Stroke.Subtle}"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentDefaultBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentSecondaryBrush" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{StaticResource Rdl.Stroke.Default}"/>

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource Rdl.Red}"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource Rdl.RedBright}"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource Rdl.RedDim}"/>
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="{StaticResource Rdl.Bg.Subtle}"/>
    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="{StaticResource Rdl.Red}"/>
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource Rdl.Red}"/>
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource Rdl.RedBright}"/>
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{StaticResource Rdl.RedDim}"/>

    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource Rdl.Text.Primary}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource Rdl.Text.Secondary}"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource Rdl.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource Rdl.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="{StaticResource Rdl.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="{StaticResource Rdl.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="{StaticResource Rdl.Text.OnAccent}"/>

    <SolidColorBrush x:Key="AccentControlElevationBorderBrush" Color="{StaticResource Rdl.Red}"/>
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{StaticResource Rdl.Stroke.Default}"/>
    <SolidColorBrush x:Key="CircleElevationBorderBrush" Color="{StaticResource Rdl.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource Rdl.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderFocusedBrush" Color="{StaticResource Rdl.Red}"/>

    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource Rdl.Success}"/>
    <SolidColorBrush x:Key="SystemFillColorSuccessBackgroundBrush" Color="{StaticResource Rdl.SuccessBg}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{StaticResource Rdl.Caution}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBackgroundBrush" Color="{StaticResource Rdl.CautionBg}"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource Rdl.Critical}"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBackgroundBrush" Color="{StaticResource Rdl.CriticalBg}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="{StaticResource Rdl.Red}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBackgroundBrush" Color="#33E63946"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="{StaticResource Rdl.Text.Secondary}"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBackgroundBrush" Color="{StaticResource Rdl.Bg.Subtle}"/>

</ResourceDictionary>
