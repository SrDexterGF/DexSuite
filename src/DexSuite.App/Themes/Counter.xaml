<!-- =====================================================================
     COUNTER — naranja (#DE9B35) sobre negro.
===================================================================== -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Cs.Bg.Window">#FF0D0D0D</Color>
    <Color x:Key="Cs.Bg.Sidebar">#FF141414</Color>
    <Color x:Key="Cs.Bg.Card">#FF1C1C1C</Color>
    <Color x:Key="Cs.Bg.CardHover">#FF262626</Color>
    <Color x:Key="Cs.Bg.Subtle">#FF202020</Color>

    <Color x:Key="Cs.Stroke.Default">#FF353535</Color>
    <Color x:Key="Cs.Stroke.Subtle">#FF202020</Color>

    <Color x:Key="Cs.Text.Primary">#FFEDEDED</Color>
    <Color x:Key="Cs.Text.Secondary">#FF9A9A9A</Color>
    <Color x:Key="Cs.Text.Tertiary">#FF6E6E6E</Color>
    <Color x:Key="Cs.Text.OnAccent">#FF1A1206</Color>

    <Color x:Key="Cs.Accent">#FFDE9B35</Color>
    <Color x:Key="Cs.AccentBright">#FFF5A623</Color>
    <Color x:Key="Cs.AccentDim">#FFA8742A</Color>

    <Color x:Key="Cs.Success">#FF8FCB2E</Color>
    <Color x:Key="Cs.Caution">#FFF5A623</Color>
    <Color x:Key="Cs.Critical">#FFE6394A</Color>

    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource Cs.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource Cs.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource Cs.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="{StaticResource Cs.Bg.Card}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{StaticResource Cs.Bg.CardHover}"/>
    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{StaticResource Cs.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource Cs.Bg.Card}"/>
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{StaticResource Cs.Bg.CardHover}"/>

    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource Cs.Bg.Card}"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource Cs.Bg.CardHover}"/>
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource Cs.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{StaticResource Cs.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{StaticResource Cs.Bg.CardHover}"/>

    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{StaticResource Cs.Bg.Subtle}"/>
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{StaticResource Cs.Bg.Card}"/>
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="Transparent"/>

    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource Cs.Stroke.Default}"/>
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource Cs.Stroke.Subtle}"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentDefaultBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentSecondaryBrush" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{StaticResource Cs.Stroke.Default}"/>

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource Cs.Accent}"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource Cs.AccentBright}"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource Cs.AccentDim}"/>
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="{StaticResource Cs.Bg.Subtle}"/>
    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="{StaticResource Cs.Accent}"/>
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource Cs.Accent}"/>
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource Cs.AccentBright}"/>
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{StaticResource Cs.AccentDim}"/>

    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource Cs.Text.Primary}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource Cs.Text.Secondary}"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource Cs.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource Cs.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="{StaticResource Cs.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="{StaticResource Cs.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="{StaticResource Cs.Text.OnAccent}"/>

    <SolidColorBrush x:Key="AccentControlElevationBorderBrush" Color="{StaticResource Cs.Accent}"/>
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{StaticResource Cs.Stroke.Default}"/>
    <SolidColorBrush x:Key="CircleElevationBorderBrush" Color="{StaticResource Cs.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource Cs.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderFocusedBrush" Color="{StaticResource Cs.Accent}"/>

    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource Cs.Success}"/>
    <SolidColorBrush x:Key="SystemFillColorSuccessBackgroundBrush" Color="#338FCB2E"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{StaticResource Cs.Caution}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBackgroundBrush" Color="#33F5A623"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource Cs.Critical}"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBackgroundBrush" Color="#33E6394A"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="{StaticResource Cs.Accent}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBackgroundBrush" Color="#33DE9B35"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="{StaticResource Cs.Text.Secondary}"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBackgroundBrush" Color="{StaticResource Cs.Bg.Subtle}"/>

</ResourceDictionary>
