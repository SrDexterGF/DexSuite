<!-- =====================================================================
     LEGENDS — dorado (#C89B3C) + azul sobre azul muy oscuro.
===================================================================== -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Lol.Bg.Window">#FF0A1428</Color>
    <Color x:Key="Lol.Bg.Sidebar">#FF0E1A30</Color>
    <Color x:Key="Lol.Bg.Card">#FF132743</Color>
    <Color x:Key="Lol.Bg.CardHover">#FF1E3A5F</Color>
    <Color x:Key="Lol.Bg.Subtle">#FF16304F</Color>

    <Color x:Key="Lol.Stroke.Default">#FF1E4D6B</Color>
    <Color x:Key="Lol.Stroke.Subtle">#FF16304F</Color>

    <Color x:Key="Lol.Text.Primary">#FFF0E6D2</Color>
    <Color x:Key="Lol.Text.Secondary">#FFA09B8C</Color>
    <Color x:Key="Lol.Text.Tertiary">#FF6E6A5E</Color>
    <Color x:Key="Lol.Text.OnAccent">#FF091428</Color>

    <Color x:Key="Lol.Accent">#FFC89B3C</Color>
    <Color x:Key="Lol.AccentBright">#FFD4AF37</Color>
    <Color x:Key="Lol.AccentDim">#FF8A6E2F</Color>
    <Color x:Key="Lol.Secondary">#FF0AC8B9</Color>

    <Color x:Key="Lol.Success">#FF0AC8B9</Color>
    <Color x:Key="Lol.Caution">#FFC89B3C</Color>
    <Color x:Key="Lol.Critical">#FFC8413B</Color>

    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource Lol.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource Lol.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource Lol.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="{StaticResource Lol.Bg.Card}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{StaticResource Lol.Bg.CardHover}"/>
    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{StaticResource Lol.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource Lol.Bg.Card}"/>
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{StaticResource Lol.Bg.CardHover}"/>

    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource Lol.Bg.Card}"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource Lol.Bg.CardHover}"/>
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource Lol.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{StaticResource Lol.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{StaticResource Lol.Bg.CardHover}"/>

    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{StaticResource Lol.Bg.Subtle}"/>
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{StaticResource Lol.Bg.Card}"/>
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="Transparent"/>

    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource Lol.Stroke.Default}"/>
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource Lol.Stroke.Subtle}"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentDefaultBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentSecondaryBrush" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{StaticResource Lol.Stroke.Default}"/>

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource Lol.Accent}"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource Lol.AccentBright}"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource Lol.AccentDim}"/>
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="{StaticResource Lol.Bg.Subtle}"/>
    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="{StaticResource Lol.Accent}"/>
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource Lol.Accent}"/>
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource Lol.AccentBright}"/>
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{StaticResource Lol.AccentDim}"/>

    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource Lol.Text.Primary}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource Lol.Text.Secondary}"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource Lol.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource Lol.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="{StaticResource Lol.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="{StaticResource Lol.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="{StaticResource Lol.Text.OnAccent}"/>

    <SolidColorBrush x:Key="AccentControlElevationBorderBrush" Color="{StaticResource Lol.Accent}"/>
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{StaticResource Lol.Stroke.Default}"/>
    <SolidColorBrush x:Key="CircleElevationBorderBrush" Color="{StaticResource Lol.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource Lol.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderFocusedBrush" Color="{StaticResource Lol.Accent}"/>

    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource Lol.Success}"/>
    <SolidColorBrush x:Key="SystemFillColorSuccessBackgroundBrush" Color="#330AC8B9"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{StaticResource Lol.Caution}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBackgroundBrush" Color="#33C89B3C"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource Lol.Critical}"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBackgroundBrush" Color="#33C8413B"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="{StaticResource Lol.Accent}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBackgroundBrush" Color="#33C89B3C"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="{StaticResource Lol.Text.Secondary}"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBackgroundBrush" Color="{StaticResource Lol.Bg.Subtle}"/>

</ResourceDictionary>
