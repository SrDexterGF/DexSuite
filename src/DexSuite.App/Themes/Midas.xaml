<!-- =====================================================================
     MIDAS — Paleta premium oro + negro cálido.
     Acabados de marca de lujo, contraste alto, sin estridencias.
===================================================================== -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Apx.Bg.Window">#FF0A0907</Color>
    <Color x:Key="Apx.Bg.Sidebar">#FF13110D</Color>
    <Color x:Key="Apx.Bg.Card">#FF1A1612</Color>
    <Color x:Key="Apx.Bg.CardHover">#FF251F18</Color>
    <Color x:Key="Apx.Bg.Subtle">#FF2D261E</Color>

    <Color x:Key="Apx.Stroke.Default">#FF3C342B</Color>
    <Color x:Key="Apx.Stroke.Subtle">#FF26211A</Color>

    <Color x:Key="Apx.Text.Primary">#FFFAF6EE</Color>
    <Color x:Key="Apx.Text.Secondary">#FFC5B9A0</Color>
    <Color x:Key="Apx.Text.Tertiary">#FF7A6F58</Color>
    <Color x:Key="Apx.Text.OnAccent">#FF1A1612</Color>

    <Color x:Key="Apx.Gold">#FFD4AF37</Color>
    <Color x:Key="Apx.GoldBright">#FFFFD700</Color>
    <Color x:Key="Apx.GoldDim">#FF8B7500</Color>

    <Color x:Key="Apx.Success">#FF8FE9B0</Color>
    <Color x:Key="Apx.SuccessBg">#338FE9B0</Color>
    <Color x:Key="Apx.Caution">#FFE6B800</Color>
    <Color x:Key="Apx.CautionBg">#33E6B800</Color>
    <Color x:Key="Apx.Critical">#FFE57373</Color>
    <Color x:Key="Apx.CriticalBg">#33E57373</Color>

    <Color x:Key="Theme.Preview.Color1">#FF13110D</Color>
    <Color x:Key="Theme.Preview.Color2">#FFD4AF37</Color>
    <Color x:Key="Theme.Preview.Color3">#FFFFD700</Color>

    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource Apx.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource Apx.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource Apx.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="{StaticResource Apx.Bg.Card}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{StaticResource Apx.Bg.CardHover}"/>

    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{StaticResource Apx.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource Apx.Bg.Card}"/>
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{StaticResource Apx.Bg.CardHover}"/>

    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource Apx.Bg.Card}"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource Apx.Bg.CardHover}"/>
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource Apx.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{StaticResource Apx.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{StaticResource Apx.Bg.CardHover}"/>

    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{StaticResource Apx.Bg.Subtle}"/>
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{StaticResource Apx.Bg.Card}"/>
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="Transparent"/>

    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource Apx.Stroke.Default}"/>
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource Apx.Stroke.Subtle}"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentDefaultBrush" Color="#331A1612"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentSecondaryBrush" Color="#221A1612"/>
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{StaticResource Apx.Stroke.Default}"/>

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource Apx.Gold}"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource Apx.GoldBright}"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource Apx.GoldDim}"/>
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="{StaticResource Apx.Bg.Subtle}"/>
    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="{StaticResource Apx.Gold}"/>
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource Apx.Gold}"/>
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource Apx.GoldBright}"/>
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{StaticResource Apx.GoldDim}"/>

    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource Apx.Text.Primary}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource Apx.Text.Secondary}"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource Apx.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource Apx.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="{StaticResource Apx.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="{StaticResource Apx.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="{StaticResource Apx.Text.OnAccent}"/>

    <SolidColorBrush x:Key="AccentControlElevationBorderBrush" Color="{StaticResource Apx.Gold}"/>
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{StaticResource Apx.Stroke.Default}"/>
    <SolidColorBrush x:Key="CircleElevationBorderBrush" Color="{StaticResource Apx.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource Apx.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderFocusedBrush" Color="{StaticResource Apx.Gold}"/>

    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource Apx.Success}"/>
    <SolidColorBrush x:Key="SystemFillColorSuccessBackgroundBrush" Color="{StaticResource Apx.SuccessBg}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{StaticResource Apx.Caution}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBackgroundBrush" Color="{StaticResource Apx.CautionBg}"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource Apx.Critical}"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBackgroundBrush" Color="{StaticResource Apx.CriticalBg}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="{StaticResource Apx.Gold}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBackgroundBrush" Color="#33D4AF37"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="{StaticResource Apx.Text.Secondary}"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBackgroundBrush" Color="{StaticResource Apx.Bg.Subtle}"/>

</ResourceDictionary>
