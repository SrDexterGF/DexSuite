<!-- =====================================================================
     CRAFTER — verde césped (#5FB04D) + marrón tierra (#8B5A2B).
===================================================================== -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Mc.Bg.Window">#FF161A0E</Color>
    <Color x:Key="Mc.Bg.Sidebar">#FF1C2113</Color>
    <Color x:Key="Mc.Bg.Card">#FF252B18</Color>
    <Color x:Key="Mc.Bg.CardHover">#FF313920</Color>
    <Color x:Key="Mc.Bg.Subtle">#FF2A311C</Color>

    <Color x:Key="Mc.Stroke.Default">#FF3D4628</Color>
    <Color x:Key="Mc.Stroke.Subtle">#FF2A311C</Color>

    <Color x:Key="Mc.Text.Primary">#FFE8E6D5</Color>
    <Color x:Key="Mc.Text.Secondary">#FF9A9B7E</Color>
    <Color x:Key="Mc.Text.Tertiary">#FF6E6F58</Color>
    <Color x:Key="Mc.Text.OnAccent">#FF0C1206</Color>

    <Color x:Key="Mc.Accent">#FF5FB04D</Color>
    <Color x:Key="Mc.AccentBright">#FF7FD05F</Color>
    <Color x:Key="Mc.AccentDim">#FF4A8B3C</Color>
    <Color x:Key="Mc.Secondary">#FF8B5A2B</Color>

    <Color x:Key="Mc.Success">#FF5FB04D</Color>
    <Color x:Key="Mc.Caution">#FFC8902B</Color>
    <Color x:Key="Mc.Critical">#FFC8413B</Color>

    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource Mc.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource Mc.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource Mc.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="{StaticResource Mc.Bg.Card}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{StaticResource Mc.Bg.CardHover}"/>
    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{StaticResource Mc.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource Mc.Bg.Card}"/>
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{StaticResource Mc.Bg.CardHover}"/>

    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource Mc.Bg.Card}"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource Mc.Bg.CardHover}"/>
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource Mc.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{StaticResource Mc.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{StaticResource Mc.Bg.CardHover}"/>

    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{StaticResource Mc.Bg.Subtle}"/>
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{StaticResource Mc.Bg.Card}"/>
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="Transparent"/>

    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource Mc.Stroke.Default}"/>
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource Mc.Stroke.Subtle}"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentDefaultBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentSecondaryBrush" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{StaticResource Mc.Stroke.Default}"/>

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource Mc.Accent}"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource Mc.AccentBright}"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource Mc.AccentDim}"/>
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="{StaticResource Mc.Bg.Subtle}"/>
    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="{StaticResource Mc.Accent}"/>
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource Mc.Accent}"/>
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource Mc.AccentBright}"/>
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{StaticResource Mc.AccentDim}"/>

    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource Mc.Text.Primary}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource Mc.Text.Secondary}"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource Mc.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource Mc.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="{StaticResource Mc.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="{StaticResource Mc.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="{StaticResource Mc.Text.OnAccent}"/>

    <SolidColorBrush x:Key="AccentControlElevationBorderBrush" Color="{StaticResource Mc.Accent}"/>
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{StaticResource Mc.Stroke.Default}"/>
    <SolidColorBrush x:Key="CircleElevationBorderBrush" Color="{StaticResource Mc.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource Mc.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderFocusedBrush" Color="{StaticResource Mc.Accent}"/>

    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource Mc.Success}"/>
    <SolidColorBrush x:Key="SystemFillColorSuccessBackgroundBrush" Color="#335FB04D"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{StaticResource Mc.Caution}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBackgroundBrush" Color="#33C8902B"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource Mc.Critical}"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBackgroundBrush" Color="#33C8413B"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="{StaticResource Mc.Accent}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBackgroundBrush" Color="#335FB04D"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="{StaticResource Mc.Text.Secondary}"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBackgroundBrush" Color="{StaticResource Mc.Bg.Subtle}"/>

</ResourceDictionary>
