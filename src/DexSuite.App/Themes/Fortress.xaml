<!-- =====================================================================
     FORTRESS — azul (#00B4FF) + amarillo (#FFE54C) sobre azul-morado oscuro.
===================================================================== -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Fn.Bg.Window">#FF12152E</Color>
    <Color x:Key="Fn.Bg.Sidebar">#FF171B3A</Color>
    <Color x:Key="Fn.Bg.Card">#FF1F2547</Color>
    <Color x:Key="Fn.Bg.CardHover">#FF2A3157</Color>
    <Color x:Key="Fn.Bg.Subtle">#FF252B50</Color>

    <Color x:Key="Fn.Stroke.Default">#FF353D6B</Color>
    <Color x:Key="Fn.Stroke.Subtle">#FF252B50</Color>

    <Color x:Key="Fn.Text.Primary">#FFF2F5FF</Color>
    <Color x:Key="Fn.Text.Secondary">#FF9AA3C8</Color>
    <Color x:Key="Fn.Text.Tertiary">#FF6E769C</Color>
    <Color x:Key="Fn.Text.OnAccent">#FF06112B</Color>

    <Color x:Key="Fn.Accent">#FF00B4FF</Color>
    <Color x:Key="Fn.AccentBright">#FF3DCBFF</Color>
    <Color x:Key="Fn.AccentDim">#FF0080BF</Color>
    <Color x:Key="Fn.Secondary">#FFFFE54C</Color>

    <Color x:Key="Fn.Success">#FF00D9A0</Color>
    <Color x:Key="Fn.Caution">#FFFFE54C</Color>
    <Color x:Key="Fn.Critical">#FFFF5470</Color>

    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource Fn.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource Fn.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource Fn.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="{StaticResource Fn.Bg.Card}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{StaticResource Fn.Bg.CardHover}"/>
    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{StaticResource Fn.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource Fn.Bg.Card}"/>
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{StaticResource Fn.Bg.CardHover}"/>

    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource Fn.Bg.Card}"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource Fn.Bg.CardHover}"/>
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource Fn.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{StaticResource Fn.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{StaticResource Fn.Bg.CardHover}"/>

    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{StaticResource Fn.Bg.Subtle}"/>
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{StaticResource Fn.Bg.Card}"/>
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="Transparent"/>

    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource Fn.Stroke.Default}"/>
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource Fn.Stroke.Subtle}"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentDefaultBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentSecondaryBrush" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{StaticResource Fn.Stroke.Default}"/>

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource Fn.Accent}"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource Fn.AccentBright}"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource Fn.AccentDim}"/>
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="{StaticResource Fn.Bg.Subtle}"/>
    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="{StaticResource Fn.Accent}"/>
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource Fn.Accent}"/>
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource Fn.AccentBright}"/>
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{StaticResource Fn.AccentDim}"/>

    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource Fn.Text.Primary}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource Fn.Text.Secondary}"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource Fn.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource Fn.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="{StaticResource Fn.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="{StaticResource Fn.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="{StaticResource Fn.Text.OnAccent}"/>

    <SolidColorBrush x:Key="AccentControlElevationBorderBrush" Color="{StaticResource Fn.Accent}"/>
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{StaticResource Fn.Stroke.Default}"/>
    <SolidColorBrush x:Key="CircleElevationBorderBrush" Color="{StaticResource Fn.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource Fn.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderFocusedBrush" Color="{StaticResource Fn.Accent}"/>

    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource Fn.Success}"/>
    <SolidColorBrush x:Key="SystemFillColorSuccessBackgroundBrush" Color="#3300D9A0"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{StaticResource Fn.Secondary}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBackgroundBrush" Color="#33FFE54C"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource Fn.Critical}"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBackgroundBrush" Color="#33FF5470"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="{StaticResource Fn.Accent}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBackgroundBrush" Color="#3300B4FF"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="{StaticResource Fn.Text.Secondary}"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBackgroundBrush" Color="{StaticResource Fn.Bg.Subtle}"/>

</ResourceDictionary>
