<!-- =====================================================================
     CYBERNETIC — Paleta cyberpunk de DexSuite (cian + violeta neón)
     Se carga DESPUÉS del ThemesDictionary Dark de Wpf.Ui para sobreescribir
     los brushes principales. Cualquier control que use {DynamicResource}
     se actualiza automáticamente.

     Filosofía: saturación atenuada respecto al neón puro para no cansar
     la vista en sesiones largas. Los colores "encendidos" se reservan para
     los hover/active y para los botones de acción primaria.
===================================================================== -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Paleta base ============ -->
    <!-- Fondos -->
    <Color x:Key="Cyb.Bg.Window">#FF0A0A1A</Color>      <!-- Ventana principal -->
    <Color x:Key="Cyb.Bg.Sidebar">#FF0F0F1F</Color>     <!-- Sidebar -->
    <Color x:Key="Cyb.Bg.Card">#FF14142A</Color>        <!-- Cards / superficies -->
    <Color x:Key="Cyb.Bg.CardHover">#FF1A1A38</Color>   <!-- Card hover -->
    <Color x:Key="Cyb.Bg.Subtle">#FF1F1F3D</Color>      <!-- Chips, badges secundarios -->

    <!-- Bordes -->
    <Color x:Key="Cyb.Stroke.Default">#FF2A2A4A</Color>
    <Color x:Key="Cyb.Stroke.Subtle">#FF1F1F3D</Color>

    <!-- Texto -->
    <Color x:Key="Cyb.Text.Primary">#FFE8F4F8</Color>
    <Color x:Key="Cyb.Text.Secondary">#FF8C97A8</Color>
    <Color x:Key="Cyb.Text.Tertiary">#FF6B7280</Color>
    <Color x:Key="Cyb.Text.OnAccent">#FF050511</Color>

    <!-- Acento primario CIAN -->
    <Color x:Key="Cyb.Cyan">#FF00B8D9</Color>           <!-- Cian atenuado, default -->
    <Color x:Key="Cyb.CyanBright">#FF00E5FF</Color>     <!-- Cian neón, hover/glow -->
    <Color x:Key="Cyb.CyanDim">#FF007A99</Color>        <!-- Cian apagado, secondary -->

    <!-- Acento secundario VIOLETA -->
    <Color x:Key="Cyb.Violet">#FF9D4EDD</Color>
    <Color x:Key="Cyb.VioletBright">#FFB026FF</Color>

    <!-- Semánticos -->
    <Color x:Key="Cyb.Success">#FF00D9A0</Color>        <!-- verde-cian -->
    <Color x:Key="Cyb.SuccessBg">#3300D9A0</Color>      <!-- 20% alpha para chip -->
    <Color x:Key="Cyb.Caution">#FFFFB800</Color>
    <Color x:Key="Cyb.CautionBg">#33FFB800</Color>
    <Color x:Key="Cyb.Critical">#FFFF5470</Color>
    <Color x:Key="Cyb.CriticalBg">#33FF5470</Color>

    <!-- ============ Override de los brushes de WPF-UI ============ -->
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource Cyb.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource Cyb.Bg.Window}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource Cyb.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="{StaticResource Cyb.Bg.Card}"/>
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="{StaticResource Cyb.Bg.CardHover}"/>

    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{StaticResource Cyb.Bg.Sidebar}"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource Cyb.Bg.Card}"/>
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{StaticResource Cyb.Bg.CardHover}"/>

    <!-- Control fills (cards, inputs) -->
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource Cyb.Bg.Card}"/>
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource Cyb.Bg.CardHover}"/>
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource Cyb.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{StaticResource Cyb.Bg.Subtle}"/>
    <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ControlFillColorInputActiveBrush" Color="{StaticResource Cyb.Bg.CardHover}"/>

    <!-- Subtle fills -->
    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="{StaticResource Cyb.Bg.Subtle}"/>
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="{StaticResource Cyb.Bg.Card}"/>
    <SolidColorBrush x:Key="SubtleFillColorDisabledBrush" Color="Transparent"/>

    <!-- Strokes -->
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource Cyb.Stroke.Default}"/>
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource Cyb.Stroke.Subtle}"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentDefaultBrush" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ControlStrokeColorOnAccentSecondaryBrush" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{StaticResource Cyb.Stroke.Default}"/>

    <!-- Acento (botones primarios, item activo sidebar, etc) -->
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource Cyb.Cyan}"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource Cyb.CyanBright}"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource Cyb.CyanDim}"/>
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="{StaticResource Cyb.Bg.Subtle}"/>
    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="{StaticResource Cyb.Cyan}"/>
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource Cyb.Cyan}"/>
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource Cyb.CyanBright}"/>
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{StaticResource Cyb.CyanDim}"/>

    <!-- Texto -->
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource Cyb.Text.Primary}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource Cyb.Text.Secondary}"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource Cyb.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource Cyb.Text.Tertiary}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="{StaticResource Cyb.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="{StaticResource Cyb.Text.OnAccent}"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush" Color="{StaticResource Cyb.Text.OnAccent}"/>

    <!-- Bordes acentuados (focus rings, etc) -->
    <SolidColorBrush x:Key="AccentControlElevationBorderBrush" Color="{StaticResource Cyb.Cyan}"/>
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{StaticResource Cyb.Stroke.Default}"/>
    <SolidColorBrush x:Key="CircleElevationBorderBrush" Color="{StaticResource Cyb.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource Cyb.Stroke.Default}"/>
    <SolidColorBrush x:Key="TextControlBorderFocusedBrush" Color="{StaticResource Cyb.Cyan}"/>

    <!-- Semánticos (chips Seguro/Riesgo y badges futuros de impacto) -->
    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource Cyb.Success}"/>
    <SolidColorBrush x:Key="SystemFillColorSuccessBackgroundBrush" Color="{StaticResource Cyb.SuccessBg}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{StaticResource Cyb.Violet}"/>
    <SolidColorBrush x:Key="SystemFillColorCautionBackgroundBrush" Color="#339D4EDD"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource Cyb.Critical}"/>
    <SolidColorBrush x:Key="SystemFillColorCriticalBackgroundBrush" Color="{StaticResource Cyb.CriticalBg}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="{StaticResource Cyb.Cyan}"/>
    <SolidColorBrush x:Key="SystemFillColorAttentionBackgroundBrush" Color="#3300B8D9"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="{StaticResource Cyb.Text.Secondary}"/>
    <SolidColorBrush x:Key="SystemFillColorNeutralBackgroundBrush" Color="{StaticResource Cyb.Bg.Subtle}"/>

    <!-- Gradiente cian → violeta para el badge EXTREMO y el botón principal -->
    <LinearGradientBrush x:Key="Cyb.AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="{StaticResource Cyb.Cyan}"/>
        <GradientStop Offset="1" Color="{StaticResource Cyb.Violet}"/>
    </LinearGradientBrush>

</ResourceDictionary>
